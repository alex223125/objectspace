<div class="max-w-6xl p-4 rounded-lg bg-gray-50 dark:bg-gray-800" data-controller="content_area" data-target="content_area.area">
  <!--center -->
  <div class="flex justify-between px-4 mx-auto max-w-screen-xl">
    <div class="w-full format-sm sm:format-base lg:format-lg format-blue dark:format-invert">
      <div class="mb-4 lg:mb-6 not-format p-3">
        <h1 id="section-<%=article_version.uuid%>" class="break-words mb-4 text-3xl font-extrabold leading-tight text-gray-900 lg:mb-6 lg:text-4xl dark:text-white">
          # <%= article_version.title %>
        </h1>

        <!-- submenu -->
        <div class="mt-1 flex flex-col space-x-4 sm:mt-0 sm:flex-row sm:flex-wrap sm:space-x-6">
          <div class="mt-2 flex items-center text-sm">
            <%= render "article/article_versions/partials/article_content/submenu/version_select_bar", article_version: article_version %>
          </div>

          <div class="mt-2 flex items-center text-sm">
            <%= render "article/article_versions/partials/article_content/submenu/copy_to_clipboard", article: article_version.article %>
          </div>

          <div class="mt-2 flex items-center text-sm text-gray-500">
            <%= render "article/article_versions/partials/article_content/submenu/options_dropdown", article_version: article_version %>
          </div>

          <div class="mt-2 flex items-center text-sm text-gray-500">
            (Link to source page)
          </div>
        </div>

        <!--      TOC-->
        <%= render "article/article_versions/partials/article_content/toc", article_version: article_version %>
        <br>

      </div>

      <div class="content-section" id="content">
        # Instruction:
        <%= article_version.content.html_safe %>
      </div>
      <br>

      <% if article_version.sources.present? %>
        <div class="sources-section" id="sources">
          # Sources:
          <%= article_version.sources.html_safe %>
        </div>
        <br>
      <% end %>

      <% if article_version.additional_information.present? %>
        <div class="additional-information-section" id="additional-information">
          # Additional information:
          <%= article_version.additional_information.html_safe %>
        </div>
        <br>
      <% end %>

      <%= render "article/article_versions/partials/article_content/contribute" %>
      <br>

      <!-- TODO: add link to disucssion -->
      <%#= render "article/article_versions/partials/article_content/comments" %>

    </div>
  </div>
</div>
<!--DEVIDER-->
<div class="inline-flex items-center justify-center w-full">
  <hr class="w-64 h-1 my-8 bg-gray-200 border-0 rounded dark:bg-gray-700">
  <div class="absolute px-4 -translate-x-1/2 bg-white left-1/2 dark:bg-gray-900">
    <svg class="w-4 h-4 text-gray-700 dark:text-gray-300" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 18 14">
      <path d="M6 0H2a2 2 0 0 0-2 2v4a2 2 0 0 0 2 2h4v1a3 3 0 0 1-3 3H2a1 1 0 0 0 0 2h1a5.006 5.006 0 0 0 5-5V2a2 2 0 0 0-2-2Zm10 0h-4a2 2 0 0 0-2 2v4a2 2 0 0 0 2 2h4v1a3 3 0 0 1-3 3h-1a1 1 0 0 0 0 2h1a5.006 5.006 0 0 0 5-5V2a2 2 0 0 0-2-2Z"/>
    </svg>
  </div>
</div>
