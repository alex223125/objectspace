<div class="w-full">
  <% if notice.present? %>
    <p class="py-2 px-3 bg-green-50 mb-5 text-green-500 font-medium rounded-lg inline-block" id="notice"><%= notice %></p>
  <% end %>

  <div class="flex justify-between items-center">
    <h1 class="font-bold text-4xl">Cheat sheet group versions</h1>
    <%= link_to 'New cheat sheet group version', new_cheat_sheet_group_version_path, class: "rounded-lg py-3 px-5 bg-blue-600 text-white block font-medium" %>
  </div>

  <div id="cheat_sheet_group_versions" class="min-w-full">
    <%= render @cheat_sheet_group_versions %>
  </div>
</div>
