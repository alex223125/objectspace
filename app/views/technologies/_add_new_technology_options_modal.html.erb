<div class="block space-y-4 md:flex md:space-y-0 md:space-x-4">
  <!-- Modal toggle -->
  <button data-modal-target="extralarge-modal" data-modal-toggle="extralarge-modal" class="block w-full md:w-auto text-white bg-blue-700 hover:bg-blue-800 focus:ring-4 focus:outline-none focus:ring-blue-300 font-medium rounded-lg text-sm px-5 py-2.5 text-center dark:bg-blue-600 dark:hover:bg-blue-700 dark:focus:ring-blue-800" type="button">
    + Add new technology
  </button>
</div>

<!-- Extra Large Modal -->
<div id="extralarge-modal" tabindex="-1" class="fixed top-0 left-0 right-0 z-50 hidden w-full p-4 overflow-x-hidden overflow-y-auto md:inset-0 h-[calc(100%-1rem)] max-h-full">
  <div class="relative w-full max-w-7xl max-h-full">
    <!-- Modal content -->
    <div class="relative bg-white rounded-lg shadow dark:bg-gray-700">
      <!-- Modal header -->
      <div class="flex items-center justify-between p-5 border-b rounded-t dark:border-gray-600">
        <h3 class="text-xl font-medium text-gray-900 dark:text-white">
          Add new Technology
        </h3>
        <button type="button" class="text-gray-400 bg-transparent hover:bg-gray-200 hover:text-gray-900 rounded-lg text-sm p-1.5 ml-auto inline-flex items-center dark:hover:bg-gray-600 dark:hover:text-white" data-modal-hide="extralarge-modal">
          <svg aria-hidden="true" class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"></path></svg>
          <span class="sr-only">Close modal</span>
        </button>
      </div>

      <!-- Modal body -->
      <div class="p-6 space-y-6">

        <!-- Part 1. Articles and Algorithms -->
        <h2 class="text-2xl font-bold leading-7 text-gray-900 sm:truncate sm:text-1xl sm:tracking-tight text-center">Article</h2>

        <p class="text-base leading-relaxed text-gray-500 dark:text-gray-400">
          In this section you can choose tools to work with reference information.
        </p>

        <div class="p-6 bg-white border border-gray-200 rounded-lg shadow dark:bg-gray-800 dark:border-gray-700">
          <a href="#">
            <h5 class="mb-2 text-2xl font-bold tracking-tight text-gray-900 dark:text-white">Add new Article</h5>
          </a>
          <p class="mb-3 font-normal text-gray-700 dark:text-gray-400">Articles are useful for reference information such as links to useful tools, bibliography, useful websites etc.</p>
          <% if target_type == "folder" %>
            <%= link_to "Create new article", new_article_article_path(target_folder: target_folder), class: "text-white bg-blue-700 hover:bg-blue-800 focus:ring-4 focus:outline-none focus:ring-blue-300 font-medium rounded-lg text-sm px-5 py-2.5 text-center mr-3 md:mr-0 dark:bg-blue-600 dark:hover:bg-blue-700 dark:focus:ring-blue-800" %>
          <% elsif target_type == "repository" %>
            <%= link_to "Create new article", new_article_article_path(target_repository: repository), class: "text-white bg-blue-700 hover:bg-blue-800 focus:ring-4 focus:outline-none focus:ring-blue-300 font-medium rounded-lg text-sm px-5 py-2.5 text-center mr-3 md:mr-0 dark:bg-blue-600 dark:hover:bg-blue-700 dark:focus:ring-blue-800" %>
          <% end %>
        </div>



        <!-- Part 2. Methods and Algorithms -->
        <h2 class="text-2xl font-bold leading-7 text-gray-900 sm:truncate sm:text-1xl sm:tracking-tight text-center">Methods and Algorithms</h2>

        <p class="text-base leading-relaxed text-gray-500 dark:text-gray-400">
          In this section you can choose tools to work with instructions.
        </p>

        <div class="p-6 bg-white border border-gray-200 rounded-lg shadow dark:bg-gray-800 dark:border-gray-700">
          <a href="#">
            <h5 class="mb-2 text-2xl font-bold tracking-tight text-gray-900 dark:text-white">Add new Method</h5>
          </a>
          <p class="mb-3 font-normal text-gray-700 dark:text-gray-400">Methods are useful for short instructions that don't require many complicated steps. Perfect for small tutorials. Think about this as a single spell which hero can cast.</p>
<!--          <a href="#" class="inline-flex items-center px-3 py-2 text-sm font-medium text-center text-white bg-blue-700 rounded-lg hover:bg-blue-800 focus:ring-4 focus:outline-none focus:ring-blue-300 dark:bg-blue-600 dark:hover:bg-blue-700 dark:focus:ring-blue-800">-->
<!--            Add new Method-->
<!--            <svg aria-hidden="true" class="w-4 h-4 ml-2 -mr-1" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"></path></svg>-->
<!--          </a>-->

          <% if target_type == "folder" %>
            <%= link_to "Create new method", new_unit_unit_path(target_folder: target_folder), class: "text-white bg-blue-700 hover:bg-blue-800 focus:ring-4 focus:outline-none focus:ring-blue-300 font-medium rounded-lg text-sm px-5 py-2.5 text-center mr-3 md:mr-0 dark:bg-blue-600 dark:hover:bg-blue-700 dark:focus:ring-blue-800" %>
          <% elsif target_type == "repository" %>
            <%= link_to "Create new method", new_unit_unit_path(target_repository: repository), class: "text-white bg-blue-700 hover:bg-blue-800 focus:ring-4 focus:outline-none focus:ring-blue-300 font-medium rounded-lg text-sm px-5 py-2.5 text-center mr-3 md:mr-0 dark:bg-blue-600 dark:hover:bg-blue-700 dark:focus:ring-blue-800" %>
          <% end %>
        </div>

        <div class="p-6 bg-white border border-gray-200 rounded-lg shadow dark:bg-gray-800 dark:border-gray-700">
          <a href="#">
            <h5 class="mb-2 text-2xl font-bold tracking-tight text-gray-900 dark:text-white">Add new Algorithm</h5>
          </a>
          <p class="mb-3 font-normal text-gray-700 dark:text-gray-400">Algorithms are useful when the instruction exceeds 3-4 steps.You can use Methods and other Algorithms as steps. When Methods and Algorithms included in your Algorithm as steps are updated, your Algorithm will also be updated accordingly. Think of Algorithm as a "combo" that the Hero can use to reach his goal.</p>
          <p class="mb-3 font-normal text-gray-700 dark:text-gray-400">If you do not know what to choose, Method or Algorithm, it's recommended to start by using the method as a tool. Once you know what your final instruction looks like, you can rewrite it as Algorithm.</p>
<!--          <a href="#" class="inline-flex items-center px-3 py-2 text-sm font-medium text-center text-white bg-blue-700 rounded-lg hover:bg-blue-800 focus:ring-4 focus:outline-none focus:ring-blue-300 dark:bg-blue-600 dark:hover:bg-blue-700 dark:focus:ring-blue-800">-->
<!--            Add new Algorithm-->
<!--            <svg aria-hidden="true" class="w-4 h-4 ml-2 -mr-1" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"></path></svg>-->
<!--          </a>-->

          <% if target_type == "folder" %>
            <%= link_to "Create new algorithm",
                        new_algorithm_algorithm_path(target_folder: target_folder),
                        class: "text-white bg-blue-700 hover:bg-blue-800 focus:ring-4 focus:outline-none focus:ring-blue-300 font-medium rounded-lg text-sm px-5 py-2.5 text-center mr-3 md:mr-0 dark:bg-blue-600 dark:hover:bg-blue-700 dark:focus:ring-blue-800" %>
          <% elsif target_type == "repository" %>
            <%= link_to "Create new algorithm",
                        new_algorithm_algorithm_path(target_repository: repository),
                        class: "text-white bg-blue-700 hover:bg-blue-800 focus:ring-4 focus:outline-none focus:ring-blue-300 font-medium rounded-lg text-sm px-5 py-2.5 text-center mr-3 md:mr-0 dark:bg-blue-600 dark:hover:bg-blue-700 dark:focus:ring-blue-800" %>
          <% end %>
        </div>





        <!-- Part 3. Classes -->
        <h2 class="text-2xl font-bold leading-7 text-gray-900 sm:truncate sm:text-1xl sm:tracking-tight text-center">Classes</h2>

        <p class="text-base leading-relaxed text-gray-500 dark:text-gray-400">
          In this section, you can choose tools for organizing Articles, Methods and Algorithms into separate entities. Each kind of Class has its advantages for more systematic storage of methodologies and reference materials.
          Think about Class as a blueprint using which you can manage similar objects (decisions, strategies).
        </p>

        <div class="max-w-screen-xl mx-auto px-4">
          <!-- Grid wrapper -->
          <div class="-mx-4 flex flex-wrap">
            <!-- Grid column -->
            <div class="w-full flex flex-col p-4 sm:w-1/2 lg:w-1/3">
              <!-- Column contents -->
              <div
                class="flex flex-col flex-1 px-10 py-12 bg-white rounded-lg shadow-lg"
              >
                <div class="flex-1">
                  <h2 class="text-gray-900 text-2xl font-bold leading-snug">
                    Class for Decision Process object
                  </h2>
                  <p class="mt-2 text-base">
                    Class for Process object its an class which built around Method or Algorithm.
                    If you have method or algorithm for which you want to track progress, check yourseelf,
                    estimate how much was done, validate process - this is right choice.
                  </p>
                </div>

                <% if target_type == "folder" %>
                  <%= link_to "Create new class for Decision process object",
                              new_simple_class_simple_class_path(class_type: "decision_process_object_class", target_folder: target_folder),
                              class: "mt-6 inline-flex items-center px-6 py-3 text-white font-semibold bg-blue-700 rounded-md shadow-sm" %>
                <% elsif target_type == "repository" %>
                  <%= link_to "Create new class for Decision process object",
                              new_simple_class_simple_class_path(class_type: "decision_process_object_class", target_repository: repository),
                              class: "mt-6 inline-flex items-center px-6 py-3 text-white font-semibold bg-blue-700 rounded-md shadow-sm" %>
                <% end %>



              </div>
            </div>

            <!-- Grid column -->
            <div class="w-full flex flex-col p-4 sm:w-1/2 lg:w-1/3">
              <!-- Column contents -->
              <div
                class="flex flex-col flex-1 px-10 py-12 bg-white rounded-lg shadow-lg"
              >
                <div class="flex-1">
                  <h2 class="text-gray-900 text-2xl font-bold leading-snug">
                    Class for Decision object
                  </h2>
                  <p class="mt-2 text-base">
                    Class for Decision object is's an class wich build for specific type of decision.
                    You will be able define method of how to make decision
                    and then grow methdologies around how to validate decisiion, estimate it's state, update decision to new fresh version and etc
                  </p>
                </div>

                <% if target_type == "folder" %>
                  <%= link_to "Create new class for decision object",
                              new_simple_class_simple_class_path(class_type: "decision_object_class", target_folder: target_folder),
                              class: "mt-6 inline-flex items-center px-6 py-3 text-white font-semibold bg-blue-700 rounded-md shadow-sm" %>
                <% elsif target_type == "repository" %>
                  <%= link_to "Create new class for decision object",
                              new_simple_class_simple_class_path(class_type: "decision_object_class", target_repository: repository),
                              class: "mt-6 inline-flex items-center px-6 py-3 text-white font-semibold bg-blue-700 rounded-md shadow-sm" %>
                <% end %>


              </div>
            </div>


            <!-- Grid column -->
            <div class="w-full flex flex-col p-4 sm:w-1/2 lg:w-1/3">
              <!-- Column contents -->
              <div
                class="flex flex-col flex-1 px-10 py-12 bg-white rounded-lg shadow-lg"
              >
                <div class="flex-1">
                  <h2 class="text-gray-900 text-2xl font-bold leading-snug">
                    Class for Strategy Object
                  </h2>
                  <p class="mt-2 text-base">
                    It's a class for Object which includes a lot of other Decision Objects and Decision process objects.
                    If you have a lot of decisions which in group organize one big, that's the right choice.
                  </p>
                </div>

                <% if target_type == "folder" %>
                  <%= link_to "Create new class for decision object container",
                              new_simple_class_simple_class_path(class_type: "decision_object_container_class", target_folder: target_folder),
                              class: "mt-6 inline-flex items-center px-6 py-3 text-white font-semibold bg-blue-700 rounded-md shadow-sm" %>
                <% elsif target_type == "repository" %>
                  <%= link_to "Create new class for decision object container",
                              new_simple_class_simple_class_path(class_type: "decision_object_container_class", target_repository: repository),
                              class: "mt-6 inline-flex items-center px-6 py-3 text-white font-semibold bg-blue-700 rounded-md shadow-sm" %>
                <% end %>

              </div>
            </div>
          </div>
        </div>


        <!-- Part 4. Framework -->
        <h2 class="text-2xl font-bold leading-7 text-gray-900 sm:truncate sm:text-1xl sm:tracking-tight text-center">Framework</h2>


        <div class="max-w-sm p-6 bg-white border border-gray-200 rounded-lg shadow dark:bg-gray-800 dark:border-gray-700">
          <a href="#">
            <h5 class="mb-2 text-2xl font-bold tracking-tight text-gray-900 dark:text-white">Framework</h5>
          </a>
          <p class="mb-3 font-normal text-gray-700 dark:text-gray-400">Framework is a blueprint using which you create your own board game with control over all processes.</p>
          <p class="mb-3 font-normal text-gray-700 dark:text-gray-400">You can start from a template and build systems using technologies developed by the community (Methods, Algorithms, Classes) and use it to play your best. By updating different pieces which you use in Framework you can increase your efficiency of how you see the game or activity and how you perform.</p>
<!--          <a href="#" class="inline-flex items-center px-3 py-2 text-sm font-medium text-center text-white bg-blue-700 rounded-lg hover:bg-blue-800 focus:ring-4 focus:outline-none focus:ring-blue-300 dark:bg-blue-600 dark:hover:bg-blue-700 dark:focus:ring-blue-800">-->
<!--            Add new Decision object-->
<!--            <svg aria-hidden="true" class="w-4 h-4 ml-2 -mr-1" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd"></path></svg>-->
<!--          </a>-->

          <% if target_type == "folder" %>
            <%= link_to "Create new Framework", new_framework_framework_path(target_folder: target_folder), class: "text-white bg-blue-700 hover:bg-blue-800 focus:ring-4 focus:outline-none focus:ring-blue-300 font-medium rounded-lg text-sm px-5 py-2.5 text-center mr-3 md:mr-0 dark:bg-blue-600 dark:hover:bg-blue-700 dark:focus:ring-blue-800" %>
          <% elsif target_type == "repository" %>
            <%= link_to "Create new Framework", new_framework_framework_path(target_repository: repository), class: "text-white bg-blue-700 hover:bg-blue-800 focus:ring-4 focus:outline-none focus:ring-blue-300 font-medium rounded-lg text-sm px-5 py-2.5 text-center mr-3 md:mr-0 dark:bg-blue-600 dark:hover:bg-blue-700 dark:focus:ring-blue-800" %>
          <% end %>


        </div>



        <!--          template -->
<!--        <div class="max-w-sm p-6 bg-white border border-gray-200 rounded-lg shadow dark:bg-gray-800 dark:border-gray-700">-->
