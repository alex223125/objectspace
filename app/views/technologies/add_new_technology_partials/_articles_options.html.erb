<h2 class="text-2xl font-bold leading-7 text-gray-900 sm:truncate sm:text-1xl sm:tracking-tight text-center">Article</h2>

<p class="text-base leading-relaxed text-gray-500 dark:text-gray-400">
  In this section you can choose tools to work with reference information.
</p>

<div class="p-6 bg-white border border-gray-200 rounded-lg shadow dark:bg-gray-800 dark:border-gray-700">
  <a href="#">
    <h5 class="mb-2 text-2xl font-bold tracking-tight text-gray-900 dark:text-white">Add new Article</h5>
  </a>
  <p class="mb-3 font-normal text-gray-700 dark:text-gray-400">Articles are useful for reference information such as links to useful tools, bibliography, useful websites etc.</p>
  <% binding.pry %>
  <% if target.is_a?(Folder) %>
    <%= link_to "Create new article", new_article_article_path(target_folder: target.uuid), class: "text-white bg-blue-700 hover:bg-blue-800 focus:ring-4 focus:outline-none focus:ring-blue-300 font-medium rounded-lg text-sm px-5 py-2.5 text-center mr-3 md:mr-0 dark:bg-blue-600 dark:hover:bg-blue-700 dark:focus:ring-blue-800" %>
  <% elsif target.is_a?(Repository) %>
    <%= link_to "Create new article", new_article_article_path(target_repository: target.uuid), class: "text-white bg-blue-700 hover:bg-blue-800 focus:ring-4 focus:outline-none focus:ring-blue-300 font-medium rounded-lg text-sm px-5 py-2.5 text-center mr-3 md:mr-0 dark:bg-blue-600 dark:hover:bg-blue-700 dark:focus:ring-blue-800" %>
  <% elsif target.is_a?(SimpleClasses::ClassContainer) %>
    <%= link_to "Create new article", new_article_article_path(target_class_container: target.uuid), class: "text-white bg-blue-700 hover:bg-blue-800 focus:ring-4 focus:outline-none focus:ring-blue-300 font-medium rounded-lg text-sm px-5 py-2.5 text-center mr-3 md:mr-0 dark:bg-blue-600 dark:hover:bg-blue-700 dark:focus:ring-blue-800" %>
  <% elsif target.is_a?(SimpleClasses::InterfaceGroup) %>
    <%= link_to "Create new article", new_article_article_path(target_interface_group: target.uuid), class: "text-white bg-blue-700 hover:bg-blue-800 focus:ring-4 focus:outline-none focus:ring-blue-300 font-medium rounded-lg text-sm px-5 py-2.5 text-center mr-3 md:mr-0 dark:bg-blue-600 dark:hover:bg-blue-700 dark:focus:ring-blue-800" %>
  <% end %>
</div>