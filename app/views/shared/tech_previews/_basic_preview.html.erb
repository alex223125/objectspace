<% scenario = scenario || nil %>
<% article = article || nil %>
<% unit = unit || nil %>
<% algorithm = algorithm || nil %>
<% cheat_sheet = cheat_sheet || nil %>
<% cheat_sheet_group = cheat_sheet_group || nil %>


<% if article.present? %>
  <% technology = article %>
<% elsif unit.present? %>
  <% technology = unit %>
<% elsif algorithm.present? %>
  <% technology = algorithm %>
<% elsif cheat_sheet.present? %>
  <% technology = cheat_sheet %>
<% elsif cheat_sheet_group.present? %>
  <% technology = cheat_sheet_group %>
<% end %>

<div class="rounded-xl border p-5 shadow-md bg-white">
  <div class="flex w-full items-center justify-between border-b pb-3">
    <div class="flex items-center space-x-3">
      <div class="h-8 w-8 rounded-full bg-slate-400 bg-[url('https://i.pravatar.cc/32')]"></div>
      <div class="text-lg font-bold text-slate-700">Joe Smith</div>
    </div>
    <div class="flex items-center space-x-8">
      <button class="rounded-2xl border bg-neutral-100 px-3 py-1 text-xs font-semibold">Category</button>
      <div class="text-xs text-neutral-500">2 hours ago</div>
      <!--  doc: works with cocoon gem because have 'remove_fields' class -->
      <% binding.pry %>
      <% if scenario == LinkAttachmentsHelper::CHEAT_SHEET_FORM_NOTES_LINK_ATTACHMENT_PREVIEW %>
        <button
          data-action="click->link_attachments_nested_form#remove_association"
          type="button"
          class="relative inline-flex items-center justify-center p-0.5 mb-2 me-2 overflow-hidden text-sm font-medium text-gray-900 rounded-lg group bg-gradient-to-br from-pink-500 to-orange-400 group-hover:from-pink-500 group-hover:to-orange-400 hover:text-white dark:text-white focus:ring-4 focus:outline-none focus:ring-pink-200 dark:focus:ring-pink-800">
          <span class="relative px-5 py-2.5 transition-all ease-in duration-75 bg-white dark:bg-gray-900 rounded-md group-hover:bg-opacity-0">
            Delete
          </span>
        </button>
      <% elsif scenario == CheatSheetGroupsHelper::CHEAT_SHEET_GROUP_SECTION_PREVIEW %>
        <button
          data-action="click->cheat_sheet_group_sections_nested_form#remove_association"
          type="button"
          class="relative inline-flex items-center justify-center p-0.5 mb-2 me-2 overflow-hidden text-sm font-medium text-gray-900 rounded-lg group bg-gradient-to-br from-pink-500 to-orange-400 group-hover:from-pink-500 group-hover:to-orange-400 hover:text-white dark:text-white focus:ring-4 focus:outline-none focus:ring-pink-200 dark:focus:ring-pink-800">
          <span class="relative px-5 py-2.5 transition-all ease-in duration-75 bg-white dark:bg-gray-900 rounded-md group-hover:bg-opacity-0">
            Delete
          </span>
        </button>
      <% elsif scenario == ArticleVersionsHelper::ARTICLE_ATTACHMENT_PREVIEW %>
        <!--  doc: works with cocoon gem because have 'remove_fields' class -->
        <button
          data-action="click->attachments_nested_form#remove_association"
          type="button"
          class="relative inline-flex items-center justify-center p-0.5 mb-2 me-2 overflow-hidden text-sm font-medium text-gray-900 rounded-lg group bg-gradient-to-br from-pink-500 to-orange-400 group-hover:from-pink-500 group-hover:to-orange-400 hover:text-white dark:text-white focus:ring-4 focus:outline-none focus:ring-pink-200 dark:focus:ring-pink-800">
          <span class="relative px-5 py-2.5 transition-all ease-in duration-75 bg-white dark:bg-gray-900 rounded-md group-hover:bg-opacity-0">
            Delete
          </span>
        </button>
      <% end %>
      <%# elsif scenario = CheatSheetGroupsHelper::CHEAT_SHEET_GROUP_SECTION_PREVIEW %>
<!--        <button class="border-2 border-gray-800 rounded-lg px-3 py-2 text-gray-400 cursor-pointer hover:bg-white hover:text-gray-200"-->
<!--                type="button"-->
<!--                data-action="click->sections_nested_form#remove_association"-->
<!--        >-->
<!--          Delete-->
<!--        </button>-->
      <%# end %>
    </div>
  </div>

  <% if unit.present? %>
    <div class="mt-4 mb-6">
      <%= link_to unit_version_path(ownername: unit.ownerable.ownername, id: unit.default_version.slug), target: '_blank' do %>
        <div class="hover:underline hover:text-blue-600 mb-3 text-xl font-bold break-words "><%= truncate(unit.title.html_safe, :length => 200, :omission => "..." , :escape => false) %></div>
      <% end %>
      <div class="text-sm text-neutral-600 break-words "><%= truncate(unit.source_page_description.html_safe, :length => 500, :omission => "..." , :escape => false) %></div>
      <br>
      <% unit_versions = unit.unit_versions %>
      Versions:
      <% unit_versions.each do |unit_version| %>
        <%= link_to unit_version_path(ownername: unit.ownerable.ownername, id: unit.default_version.slug), target: '_blank' do %>
          <div class="hover:underline hover:text-blue-600 mb-3 text-xl font-bold break-words "><%= truncate(unit_version.title.html_safe, :length => 100, :omission => "..." , :escape => false) %></div>
        <% end %>
      <% end %>
    </div>
  <% elsif algorithm.present? %>
    <div class="mt-4 mb-6">
      <%= link_to algorithm_version_path(ownername: algorithm.ownerable.ownername, id: algorithm.default_version.slug), target: '_blank' do %>
        <div class="hover:underline hover:text-blue-600 mb-3 text-xl font-bold break-words "><%= truncate(algorithm.title.html_safe, :length => 200, :omission => "..." , :escape => false) %></div>
      <% end %>
      <div class="text-sm text-neutral-600 break-words "><%= truncate(algorithm.source_page_description.html_safe, :length => 500, :omission => "..." , :escape => false) %></div>
      <br>
      <% algorithm_versions = algorithm.algorithm_versions %>
      Versions:
      <% algorithm_versions.each do |algorithm_version| %>
        <%= link_to algorithm_version_path(ownername: algorithm.ownerable.ownername, id: algorithm.default_version.slug), target: '_blank' do %>
          <div class="hover:underline hover:text-blue-600 mb-3 text-xl font-bold break-words "><%= truncate(algorithm_version.title.html_safe, :length => 100, :omission => "..." , :escape => false) %></div>
        <% end %>
      <% end %>
    </div>
  <% elsif cheat_sheet.present? %>
    <div class="mt-4 mb-6">
      <%= link_to cheat_sheet_version_path(ownername: cheat_sheet.ownerable.ownername, id: cheat_sheet.default_version), target: '_blank' do %>
        <div class="hover:underline hover:text-blue-600 mb-3 text-xl font-bold break-words "><%= truncate(cheat_sheet.title.html_safe, :length => 200, :omission => "..." , :escape => false) %></div>
      <% end %>
      <div class="text-sm text-neutral-600 break-words "><%= truncate(cheat_sheet.source_page_description.html_safe, :length => 500, :omission => "..." , :escape => false) %></div>
      <br>
      <% cheat_sheet_versions = cheat_sheet.cheat_sheet_versions %>
      Versions:
      <% cheat_sheet_versions.each do |cheat_sheet_version| %>
        <%= link_to cheat_sheet_version_path(ownername: cheat_sheet.ownerable.ownername, id: cheat_sheet.default_version), target: '_blank' do %>
          <div class="hover:underline hover:text-blue-600 mb-3 text-xl font-bold break-words "><%= truncate(cheat_sheet_version.title.html_safe, :length => 100, :omission => "..." , :escape => false) %></div>
        <% end %>
      <% end %>
    </div>
  <% elsif cheat_sheet_group.present? %>
    <div class="mt-4 mb-6">
      <%= link_to cheat_sheet_group_version_path(ownername: cheat_sheet_group.ownerable.ownername, id: cheat_sheet_group.default_version), target: '_blank' do %>
        <div class="hover:underline hover:text-blue-600 mb-3 text-xl font-bold break-words "><%= truncate(cheat_sheet_group.title.html_safe, :length => 200, :omission => "..." , :escape => false) %></div>
      <% end %>
      <div class="text-sm text-neutral-600 break-words "><%= truncate(cheat_sheet_group.source_page_description.html_safe, :length => 500, :omission => "..." , :escape => false) %></div>
      <br>
      <% cheat_sheet_group_versions = cheat_sheet_group.cheat_sheet_group_versions %>
      Versions:
      <% cheat_sheet_group_versions.each do |cheat_sheet_group_version| %>
        <%= link_to cheat_sheet_group_version_path(ownername: cheat_sheet_group.ownerable.ownername, id: cheat_sheet_group.default_version), target: '_blank' do %>
          <div class="hover:underline hover:text-blue-600 mb-3 text-xl font-bold break-words "><%= truncate(cheat_sheet_group_version.title.html_safe, :length => 100, :omission => "..." , :escape => false) %></div>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <div class="mt-4 mb-6">
      <%= link_to technology_item_path_to(technology), target: '_blank' do %>
        <div class="hover:underline mb-3 text-xl font-bold break-words "><%= truncate(technology.title.html_safe, :length => 200, :omission => "..." , :escape => false) %></div>
      <% end %>
      <div class="text-sm text-neutral-600 break-words"><%= truncate(technology.source_page_description.html_safe, :length => 500, :omission => "" , :escape => false) %></div>
    </div>
  <% end %>

  <div>
    <div class="flex items-center justify-between text-slate-500">
      <div class="flex space-x-4 md:space-x-8">

        <div class="flex cursor-pointer items-center transition hover:text-slate-600">
          <svg xmlns="http://www.w3.org/2000/svg" class="mr-1.5 h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M7 8h10M7 12h4m1 8l-4-4H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-3l-4 4z" />
          </svg>
          <span>125</span>
        </div>

        <div class="flex cursor-pointer items-center transition hover:text-slate-600">
          <svg xmlns="http://www.w3.org/2000/svg" class="mr-1.5 h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M14 10h4.764a2 2 0 011.789 2.894l-3.5 7A2 2 0 0115.263 21h-4.017c-.163 0-.326-.02-.485-.06L7 20m7-10V5a2 2 0 00-2-2h-.095c-.5 0-.905.405-.905.905 0 .714-.211 1.412-.608 2.006L7 11v9m7-10h-2M7 20H5a2 2 0 01-2-2v-6a2 2 0 012-2h2.5" />
          </svg>
          <span>4</span>
        </div>

      </div>
    </div>
  </div>
</div>
<br>
