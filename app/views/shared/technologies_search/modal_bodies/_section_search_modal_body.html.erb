<div data-controller="select_instruction_tabs"
     data-select_instruction_tabs-active-tab="inline-block p-4 border-b-2 rounded-t-lg text-blue-600 hover:text-blue-600 dark:text-blue-500 dark:hover:text-blue-500 border-blue-600 dark:border-blue-500"
     data-select_instruction_tabs-inactive-tab="inline-block p-4 border-b-2 border-transparent rounded-t-lg hover:text-gray-600 hover:border-gray-300 dark:hover:text-gray-300">

  <div class="mb-4 border-b border-gray-200 dark:border-gray-700">
    <ul class="flex flex-wrap -mb-px text-sm font-medium text-center" id="myTab" data-select_instruction_tabs-toggle="#myTabContent" role="tablist">
      <li class="mr-2" role="presentation" data-select_instruction_tabs-target="tab" data-action="click->select_instruction_tabs#change">
        <button class="inline-block p-4 border-b-2 rounded-t-lg" id="profile-tab" type="button" role="tab" aria-controls="profile" aria-selected="false">Mixed search</button>
      </li>
      <li class="mr-2" role="presentation" data-select_instruction_tabs-target="tab" data-action="click->select_instruction_tabs#change">
        <button class="inline-block p-4 border-b-2 rounded-t-lg" id="profile-tab" type="button" role="tab" aria-controls="profile" aria-selected="false">Articles</button>
      </li>
      <li class="mr-2" role="presentation" data-select_instruction_tabs-target="tab" data-action="click->select_instruction_tabs#change">
        <button class="inline-block p-4 border-b-2 rounded-t-lg" id="profile-tab" type="button" role="tab" aria-controls="units" aria-selected="false">Methods</button>
      </li>
      <li class="mr-2" role="presentation" data-select_instruction_tabs-target="tab" data-action="click->select_instruction_tabs#change">
        <button class="inline-block p-4 border-b-2 border-transparent rounded-t-lg hover:text-gray-600 hover:border-gray-300 dark:hover:text-gray-300" id="dashboard-tab" type="button" role="tab" aria-controls="dashboard" aria-selected="false">Cheat Sheets</button>
      </li>
      <li class="mr-2" role="presentation" data-select_instruction_tabs-target="tab" data-action="click->select_instruction_tabs#change">
        <button class="inline-block p-4 border-b-2 border-transparent rounded-t-lg hover:text-gray-600 hover:border-gray-300 dark:hover:text-gray-300" id="settings-tab" type="button" role="tab" aria-controls="settings" aria-selected="false">Combo Cheat Sheets</button>
      </li>
    </ul>
  </div>

  <div class="hidden py-4 px-4 border-l border-b border-r" data-select_instruction_tabs-target="panel">
    <%= render "shared/technologies_search/mixed_tech_select/search_page", scenario: scenario %>
  </div>
  <div class="hidden py-4 px-4 border-l border-b border-r" data-select_instruction_tabs-target="panel">
    <%= render "shared/technologies_search/articles/search_page", scenario: scenario %>
  </div>
  <div class="hidden py-4 px-4 border-l border-b border-r" data-select_instruction_tabs-target="panel">
    <%= render "shared/technologies_search/units/search_page", scenario: scenario %>
  </div>
  <div class="hidden py-4 px-4 border-l border-b border-r" data-select_instruction_tabs-target="panel">
    <%= render "shared/technologies_search/cheat_sheets/search_page", scenario: scenario %>
  </div>
  <div class="hidden py-4 px-4 border-l border-b border-r" data-select_instruction_tabs-target="panel">
    <%= render "shared/technologies_search/cheat_sheet_groups/search_page", scenario: scenario %>
  </div>
</div>