<% scenario ||= nil %>
<h1 class="text-2xl text-center mt-5 mb-4">Articles search form</h1>

<div data-controller="search_instructions"
     data-target="remote_select_instruction.searchInstructionsInstance remote_select_attachment.searchInstructionsInstance">

  <!--  Part 1. Search form-->
  <div class="flex justify-center">
    <%= render partial: "shared/technologies_search/shared/search_form",
               locals: { type: "articles",
                         scenario: scenario } %>
  </div>

  <!--  Part 2. Form results -->
  <h1 class="text-2xl text-center mt-5 mb-4">Search results</h1>
  <div id="units_versions_search_results"
       class="mt-4 mx-10"
       data-target="search_instructions.entries">
    <%= render "shared/technologies_search/articles/list", articles: [] %>
  </div>
  <div id="loadMoreButton" class="mt-4 mx-10 flex items-center justify-center">
    <button type="button" class="focus:outline-none text-white bg-purple-700 hover:bg-purple-800 focus:ring-4 focus:ring-purple-300 font-medium rounded-lg text-sm px-5 py-2.5 mb-2 dark:bg-purple-600 dark:hover:bg-purple-700 dark:focus:ring-purple-900">Load more</button>
  </div>
</div>
