<% scenario ||=nil %>

<div class="w-full">
  <table>
    <%= form_with(url: search_path, method: :post,
                  # data: {action: "submit->search_instructions#submit"},
                  # target: "remote_select_instruction.searchInstructionsInstance"},
                  # data-target="remote_select_instruction.searchInstructionsInstance
                  :html => { :onsubmit => "return false" }) do |form| %>

      <div class="flex flex-col">
        <!--  <h2 class="text-xl font-bold mb-4 text-stone-600">-->
        <!--    TailwindCSS Simple Filter-->
        <!--  </h2>-->


        <div class="bg-white p-6 rounded-xl shadow-lg">
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-2 xl:grid-cols-2 gap-6">

            <%= hidden_field_tag 'type', type, data: {target: "search_instructions.instructionType"}  %>

            <% if scenario.present? %>
              <%= hidden_field_tag 'scenario', scenario, data: {target: "search_instructions.scenario"}  %>
            <% end %>

            <div class="flex flex-col">
              <!--        <label for="name" class="font-medium text-sm text-stone-600">Name</label>-->
              <!--        <input-->
              <!--          type="text"-->
              <!--          id="name"-->
              <!--          placeholder="john doe"-->
              <!--          class="mt-2 block w-full rounded-md border-gray-300 shadow-sm focus:border-orange-300 focus:ring focus:ring-orange-200 focus:ring-opacity-50"-->
              <!--        >-->

              <div class="relative">
                <label for="default-search" class="mb-2 text-sm font-medium text-gray-900 sr-only dark:text-white">Search by query</label>
                <div class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none">
                  <svg aria-hidden="true" class="w-5 h-5 text-gray-500 dark:text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                </div>
                <%= form.text_field :uuid_query,
                                    data: {target: "search_instructions.uuidQuery"},
                                    class: "block w-full p-4 pl-10 text-sm text-gray-900 border border-gray-300 rounded-lg bg-gray-50 focus:ring-blue-500 focus:border-blue-500 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white dark:focus:ring-blue-500 dark:focus:border-blue-500",
                                    placeholder: "Search using unique identifier (question symbol on qa)",
                                    autocomplete: "off" %>
              </div>

            </div>

            <div class="flex flex-col">
              <!--        <label for="email" class="font-medium text-sm text-stone-600">Email</label>-->
              <!--        <input-->
              <!--          type="email"-->
              <!--          id="email"-->
              <!--          placeholder="johndoe@example.com"-->
              <!--          class="mt-2 block w-full rounded-md border-gray-300 shadow-sm focus:border-orange-300 focus:ring focus:ring-orange-200 focus:ring-opacity-50"-->
              <!--        >-->

              <div class="relative">
                <label for="default-search" class="mb-2 text-sm font-medium text-gray-900 sr-only dark:text-white">Search by uuid</label>
                <div class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none">
                  <svg aria-hidden="true" class="w-5 h-5 text-gray-500 dark:text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                </div>
                <%= form.text_field :text_query,
                                    data: {target: "search_instructions.textQuery"},
                                    class: "block w-full p-4 pl-10 text-sm text-gray-900 border border-gray-300 rounded-lg bg-gray-50 focus:ring-blue-500 focus:border-blue-500 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white dark:focus:ring-blue-500 dark:focus:border-blue-500",
                                    placeholder: "Search using text...",
                                    autocomplete: "off" %>
              </div>

            </div>

          </div>

          <div class="grid md:flex grid-cols-2 justify-end space-x-4 w-full mt-6">
            <button
              type="button"
              data-action="click->search_instructions#resetForm"
              class="text-gray-500 bg-white hover:bg-gray-100 focus:ring-4 focus:outline-none focus:ring-blue-300 rounded-lg border border-gray-200 text-sm font-medium px-5 py-2.5 hover:text-gray-900 focus:z-10 dark:bg-gray-700 dark:text-gray-300 dark:border-gray-500 dark:hover:text-white dark:hover:bg-gray-600 dark:focus:ring-gray-600">
              Reset
            </button>

            <button
              type="button"
              data-action="click->search_instructions#submit"
              class="text-white right-2.5 bottom-2.5 bg-blue-700 hover:bg-blue-800 focus:ring-4 focus:outline-none focus:ring-blue-300 font-medium rounded-lg text-sm px-4 py-2 dark:bg-blue-600 dark:hover:bg-blue-700 dark:focus:ring-blue-800">
              Search
            </button>

          </div>
        </div>
      </div>

    <% end %>
  </table>
</div>
