<!--<div data-id="<%#= f.object_name.match(/(\d+)]/)[1] %>" class="nested-fields">-->
<div class="nested-fields">
  <div class="" data-controller="step_accordion">

    <details class="" data-action="toggle->step_accordion#toggle" data-accordion-target="item">
      <summary
        class="flex items-center justify-between w-full p-5 font-medium text-left border border-gray-200 rounded-xl focus:ring-4 focus:ring-gray-200 dark:focus:ring-gray-800 dark:border-gray-700 hover:bg-gray-100 dark:hover:bg-gray-800 text-gray-500 dark:text-gray-400">
        <span>Class container №<span class="interface-group-position-visible-field">1</span>: Class container title here</span>
        <div class="ml-auto pr-10">
          <%= link_to_remove_association "Delete",
                                         f,
                                         class: "border-2 border-gray-800 rounded-lg px-3 py-2 text-gray-400 cursor-pointer
                                         hover:bg-white hover:text-gray-200"
          %>
        </div>
        <svg data-accordion-icon class="w-6 h-6 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13l-3 3m0 0l-3-3m3 3V8m0 13a9 9 0 110-18 9 9 0 010 18z"></path></svg>
      </summary>

      <div id="" aria-labelledby="accordion-arrow-icon-heading-2">
        <!--        <div class="p-5 font-light border border-b-0 border-gray-200 dark:border-gray-700">-->
        <!--          <p class="mb-2 text-gray-500 dark:text-gray-400">Flowbite is first conceptualized and designed using the Figma software so everything you see in the library has a design equivalent in our Figma file.</p>-->
        <!--          <p class="text-gray-500 dark:text-gray-400">Check out the <a href="https://flowbite.com/figma/" class="text-blue-600 dark:text-blue-500 hover:underline">Figma design system</a> based on the utility classes from Tailwind CSS and components from Flowbite.</p>-->
        <!--        </div>-->
        <div class="p-5 font-light border border-b-0 border-gray-200 dark:border-gray-700">
          <!--          <div class="nested-fields">-->
          <div class="">

            <%#= f.hidden_field :position, class: "interface-group-position-hidden-field" %>

            <div class="col-span-6 sm:col-span-3">
              <%= f.label "Class container title", class: "block text-sm font-medium text-gray-700" %>
              <%= f.hint 'Describe in short responsibility which unites group of classes.', class: "mt-2 text-sm text-gray-500" %>
              <%= f.input_field :title, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
            </div>
            <br>

            <div class="col-span-6 sm:col-span-3" data-controller="unit_instruction_tinymce">
              <%= f.label "Description", class: "block text-sm font-medium text-gray-700" %>
              <%= f.hint 'Describe in more details what unites this group of classes.', class: "mt-2 text-sm text-gray-500" %>
              <%= f.input_field :description, data: { target: 'unit_instruction_tinymce.field' } %>
            </div>
            <br>

            <%= render "shared/form_partials/containers/container_members/nested_form", :form => f, :type => "class_container" %>


            <!--            TODO: if we use partial we getting stackoverflow? WTF?-->
            <!--            SUBNESTED FORM -->
            <!--            SUBNESTED FORM -->
            <!--            SUBNESTED FORM -->
            <%= f.fields_for :containers do |t| %>
              <%= render "shared/form_partials/containers/class_containers/class_container_fields", :f => t %>
            <% end %>

            <% nesting_level = nesting_level.nil? ? SimpleClassesHelper::CLASS_CONTAINERS_NESTED_LEVELS_COUNT_BEGINNING : nesting_level + 1 %>

            <% if nesting_level <= SimpleClassesHelper::CLASS_CONTAINERS_ALLOWED_NESTED_LEVELS_AMOUNT %>
              Nesting level: <%= nesting_level %>

              <div>
                <%= link_to_add_association "Add Class Container", f,
                                            :containers,
                                            partial: 'shared/form_partials/containers/class_containers/class_container_fields',
                                            render_options: {:locals => {:nesting_level => nesting_level}},
                                            class: "nodraggablesteps inline-flex justify-center rounded-md border border-transparent bg-indigo-600 py-2 px-4 text-sm font-medium text-white shadow-sm hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2"
                %>
              </div>
            <% end %>
            <!--            SUBNESTED FORM -->
            <!--            SUBNESTED FORM -->
            <!--            SUBNESTED FORM -->


            <br>
            <div class="bg-zinc-50 px-4 py-3 sm:px-6">
              <div class="text-end">
                <%= link_to_remove_association "Delete class container",
                                               f,
                                               class: "focus:outline-none text-white bg-red-700 hover:bg-red-800 focus:ring-4
                                               focus:ring-red-300 font-medium rounded-lg text-sm px-5 py-2.5 mr-2 mb-2 dark:bg-red-600
                                               dark:hover:bg-red-700 dark:focus:ring-red-900"
                %>
                <!--      <button type="button" class="focus:outline-none text-white bg-red-700 hover:bg-red-800 focus:ring-4 focus:ring-red-300 font-medium rounded-lg text-sm px-5 py-2.5 mr-2 mb-2 dark:bg-red-600 dark:hover:bg-red-700 dark:focus:ring-red-900">Remove</button>-->
              </div>
            </div>

            <hr class="h-px my-8 bg-gray-200 border-0 dark:bg-gray-700">

          </div>
        </div>
        <hr class="w-48 h-1 mx-auto my-4 bg-gray-100 border-0 rounded md:my-10 dark:bg-gray-700">
      </div>
    </details>
  </div>
  <br>
</div>






