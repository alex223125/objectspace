<div class="nested-fields">

  <div class="col-span-6 sm:col-span-3">
    <%= f.label "Title", class: "block text-sm font-medium text-gray-700" %>
    <%= f.hint 'Briefly describe context of example.', class: "mt-2 text-sm text-gray-500" %>
    <%= f.hint '"Example of sorting 2 dimensional arrays"', class: "mt-2 text-sm text-gray-500" %>
    <%= f.hint '"Example of cooking 2 dishes at the same time"', class: "mt-2 text-sm text-gray-500" %>
    <%= f.hint '"Example of paying all bills together"', class: "mt-2 text-sm text-gray-500" %>

    <div class="bg-yellow-50 border border-yellow-400 rounded text-yellow-800 text-sm p-4 flex items-start">
      <div>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-2" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"></path>
        </svg>
      </div>
      <div class="w-full">
        <p>Recommendations how to create cool title for usage example:</p>
        <ul class="list-disc">
          <li>How I used "Method name" to do "this"</li>
          <li>Best way how I use this method to do "this"</li>
          <li>How this method can be used to do "this"</li>
        </ul>
      </div>
      <div>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </div>
    </div>


    <%= f.input_field :title, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
  </div>
  <br>

  <div class="col-span-6 sm:col-span-3" data-controller="usage_example_content_tinymce">
    <%= f.label "Content", class: "block text-sm font-medium text-gray-700" %>
    <%= f.hint 'Describe scenario or situation of method usage.', class: "mt-2 text-sm text-gray-500" %>
    <%= f.input_field :content, data: { target: 'usage_example_content_tinymce.field' } %>
  </div>
  <br>

  <div class="col-span-6 sm:col-span-3" data-controller="usage_example_sources_tinymce">
    <%= f.label "Sources (optional)", class: "block text-sm font-medium text-gray-700" %>
    <%= f.hint 'If your method based on any credible sources of information you can add it here.', class: "mt-2 text-sm text-gray-500" %>
    <%= f.input_field :sources, data: { target: 'usage_example_sources_tinymce.field' } %>
  </div>

  <br>
  <div class="bg-zinc-50 px-4 py-3 sm:px-6">
    <div class="text-end">
      <%= link_to_remove_association "Delete", f, class: "focus:outline-none text-white bg-red-700 hover:bg-red-800 focus:ring-4 focus:ring-red-300 font-medium rounded-lg text-sm px-5 py-2.5 mr-2 mb-2 dark:bg-red-600 dark:hover:bg-red-700 dark:focus:ring-red-900" %>
    </div>
  </div>

  <hr class="h-px my-8 bg-gray-200 border-0 dark:bg-gray-700">
</div>