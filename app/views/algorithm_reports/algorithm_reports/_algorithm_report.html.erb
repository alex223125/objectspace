<div id="<%= dom_id algorithm_report %>">
  <p class="my-5">
    <strong class="block font-medium mb-1">Title:</strong>
    <%= algorithm_report.title %>
  </p>

  <p class="my-5">
    <strong class="block font-medium mb-1">Description:</strong>
    <%= algorithm_report.description %>
  </p>

  <% if action_name != "show" %>
    <%= link_to "Show this algorithm report", algorithm_report, class: "rounded-lg py-3 px-5 bg-gray-100 inline-block font-medium" %>
    <%= link_to 'Edit this algorithm report', edit_algorithm_report_path(algorithm_report), class: "rounded-lg py-3 ml-2 px-5 bg-gray-100 inline-block font-medium" %>
    <hr class="mt-6">
  <% end %>
</div>
