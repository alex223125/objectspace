<div id="steps-for-algorithm-version-<%= algorithm_report.id%>" data-controller="scroll_to_step_beginning">

  <hr class="w-48 h-1 mx-auto my-4 bg-gray-100 border-0 rounded md:my-10 dark:bg-gray-700">
  <div class="text-center col-span-6 sm:col-span-3">
    <p class="text-xl font-bold hover:text-gray-700">Steps:</p>
  </div>

  <% if algorithm_report.logging_control_structures.present? %>
    <% algorithm_report.logging_control_structures.first.children.each do |logging_node| %>
      <%= render "algorithm_reports/algorithm_reports/show_partials/algorithm_report_content/nodes/node", logging_node: logging_node %>
      <br>
    <% end %>
  <% end %>
</div>
<br>
