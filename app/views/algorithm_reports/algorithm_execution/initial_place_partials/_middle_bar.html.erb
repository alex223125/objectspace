<div class="max-w-6xl p-4 rounded-lg bg-gray-50 dark:bg-gray-800" data-controller="content_area" data-target="content_area.area">
  <!--center -->
  <div class="flex justify-between px-4 mx-auto max-w-screen-xl">
    <div class="w-full format-sm sm:format-base lg:format-lg format-blue dark:format-invert">
      <div class="mb-4 lg:mb-6 not-format p-3">
        <h1 class="break-words mb-4 text-3xl font-extrabold leading-tight text-gray-900 lg:mb-6 lg:text-4xl dark:text-white">
          Initial step
        </h1>
      </div>

      <!-- Single unified card container with the enhanced sightseeing quest path -->
      <div class="w-full max-w-4xl mx-auto my-8 bg-white border-4 border-slate-900 rounded-3xl p-6 shadow-2xl relative overflow-hidden group min-h-[300px] flex items-center justify-center">

        <!-- Intricate Vintage Board Game Corner Framing Lines -->
        <div class="absolute inset-0 border-2 border-slate-100 m-2 rounded-2xl pointer-events-none"></div>
        <div class="absolute inset-0 border border-dashed border-amber-500/20 m-4 rounded-xl pointer-events-none"></div>

        <!-- PANORAMIC SIGHTSEEING MAP GRID -->
        <div class="relative w-full h-64 bg-slate-50 border-2 border-slate-900 rounded-2xl overflow-hidden flex items-center justify-center p-4">

          <!-- Topological Grid Texture Layer -->
          <div class="absolute inset-0 opacity-[0.03] bg-[radial-gradient(#000_1px,transparent_1px)] [background-size:16px_16px] pointer-events-none"></div>

          <!-- Terrain Ambience Depth Orbs -->
          <div class="absolute -top-10 left-12 w-48 h-32 bg-emerald-500/10 rounded-full blur-2xl"></div>
          <div class="absolute top-20 right-16 w-56 h-40 bg-indigo-500/5 rounded-full blur-3xl"></div>

          <!-- THE SIGHTSEEING JOURNEY PATHWAY LINES -->
          <svg class="absolute inset-0 w-full h-full text-slate-300 pointer-events-none" xmlns="http://www.w3.org" viewBox="0 0 800 200" fill="none">
            <path d="M 100 120 Q 250 30, 420 135 T 700 80" stroke="#cbd5e1" stroke-width="8" stroke-linecap="round" stroke-dasharray="1 16" />
            <path d="M 100 120 Q 250 30, 420 135 T 700 80" stroke="#94a3b8" stroke-width="2" stroke-linecap="round" stroke-dasharray="8 8" class="opacity-60" />
          </svg>

          <!-- ICON 1: THE PORTAL OF ORIGIN (Active Location Node) -->
          <div class="absolute left-[10%] top-[55%] -translate-y-1/2 flex flex-col items-center">
            <div class="relative w-16 h-16 flex items-center justify-center bg-white border-4 border-slate-900 rounded-2xl shadow-lg transition-all duration-300 group-hover:scale-110 group-hover:border-indigo-600">
              <!-- Pulse radar mapping active position lock -->
              <div class="absolute inset-0 bg-indigo-500/20 rounded-xl anonymity-70 animate-ping"></div>

              <!-- SVG Vector Asset: Sparking Portal Gateway -->
              <svg class="w-9 h-9 text-slate-900 group-hover:text-indigo-600 transition-colors" xmlns="http://www.w3.org" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244" />
              </svg>
            </div>
            <!-- Location Ring Indicator -->
            <div class="w-10 h-1.5 bg-slate-900/10 rounded-full blur-xs mt-1.5"></div>
          </div>

          <!-- ICON 2: THE MAPMASTER COMPASS MATRIX (Upcoming Strategy Milestone) -->
          <div class="absolute left-[48%] top-[62%] -translate-y-1/2 flex flex-col items-center opacity-60 transition-all duration-300 group-hover:opacity-100 group-hover:scale-105">
            <div class="w-14 h-14 flex items-center justify-center bg-white border-2 border-slate-400 border-dashed rounded-xl shadow-md transition-colors group-hover:border-slate-900">

              <!-- SVG Vector Asset: Waypoint Orientation Compass -->
              <svg class="w-7 h-7 text-slate-500 group-hover:text-slate-900 transition-colors" xmlns="http://www.w3.org" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25s-7.5-4.108-7.5-11.25a7.5 7.5 0 1 1 15 0Z" />
              </svg>
            </div>
            <div class="w-8 h-1 bg-slate-900/5 rounded-full blur-xs mt-1.5"></div>
          </div>

          <!-- NODE 3: THE VICTORY MILESTONE FLAG (The Ultimate Goal Claimed) -->
          <div class="absolute right-[8%] top-[20%] flex flex-col items-center opacity-30 transition-all duration-500 group-hover:opacity-100 group-hover:translate-y-[-6px]">
            <div class="relative w-16 h-16 flex items-center justify-center bg-white border-2 border-slate-300 rounded-full shadow-md group-hover:border-emerald-600 group-hover:bg-emerald-50/20">
              <svg class="w-8 h-8 text-slate-400 group-hover:text-emerald-600 transition-colors" xmlns="http://www.w3.org" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 3v1.5M3 21v-6m0 0h13.5a1.5 1.5 0 0 0 1.5-1.5V6a1.5 1.5 0 0 0-1.5-1.5H3m0 12V4.5M16.5 4.5V12" />
              </svg>
              <div class="absolute -top-1.5 -right-1.5 text-[10px] bg-slate-900 text-white w-5 h-5 rounded-full flex items-center justify-center border border-white font-bold group-hover:bg-emerald-600 transition-colors">🔒</div>
            </div>
            <div class="w-10 h-1 bg-slate-900/5 rounded-full blur-xs mt-1"></div>
          </div>

        </div>
      </div>


      <div class="content-section break-words" id="content-<%=introduction_step.uuid%>">
        <a href="#content-<%=introduction_step.uuid%>" >
          <h3 class="hover:underline hover:text-blue-600 text-2xl font-bold leading-7 text-gray-900 sm:truncate sm:text-1xl sm:tracking-tight text-center">Content</h3>
        </a>
        <%= introduction_step.original_introduction_step.content.html_safe %>
      </div>
      <br>

      <%= render "algorithm_reports/algorithm_execution/initial_place_partials/initial_place_navigation",
                 current_step: introduction_step,
                 algorithm_report: algorithm_report %>

    </div>
  </div>
</div>

