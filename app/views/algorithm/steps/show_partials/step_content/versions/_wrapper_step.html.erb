<% if step.description.present? %>
  <div class="break-words description-section" id="step-description-<%= step.uuid %>">
    <hr class="w-48 h-1 mx-auto my-4 bg-gray-100 border-0 rounded md:my-10 dark:bg-gray-700">
    <div class="text-center col-span-6 sm:col-span-3">
      <p class="text-xl font-bold hover:text-gray-700"># Description:</p>
    </div>
    <div class="step-description-content bg-white rounded-xl p-5">
      <%= step.description.html_safe %>
    </div>
  </div>
  <br>
<% end %>

<% if step.solves_the_problem.present? %>
  <div class="break-words solves-the-problem-section" id="step-solves-the-problem-<%= step.uuid %>">
    # Solves the problem:
    <%= step.solves_the_problem.html_safe %>
  </div>
  <br>
<% end %>

<% if step.instruction.present? %>
  <div class="break-words instruction-section" id="step-instruction-<%= step.uuid %>">
    <hr class="w-48 h-1 mx-auto my-4 bg-gray-100 border-0 rounded md:my-10 dark:bg-gray-700">
    <div class="text-center col-span-6 sm:col-span-3">
      <p class="text-xl font-bold hover:text-gray-700"># Instruction:</p>
    </div>
    <div class="step-instruction-content bg-white rounded-xl p-5">
      <%= step.instruction.html_safe %>
    </div>
  </div>
  <br>
<% end %>

<!--  content section-->
<div id="" class="attached-technology" data-target="">
  <div class="p-5 border border-b-0 border-gray-200 dark:border-gray-700 dark:bg-gray-900 bg-white">
    <div class="note-title break-words">
      Note:
    </div>
    <div class="note break-words">
      <%= step.try(:note).try(:html_safe) %>
    </div>

    <hr class="w-48 h-1 mx-auto my-4 bg-gray-100 border-0 rounded md:my-10 dark:bg-gray-700">
    <div class="text-center col-span-6 sm:col-span-3">
      <% if step.technologiable_type == "Units::Unit" %>
        <p class="text-xl font-bold hover:text-gray-700">Included Method:</p>
      <% elsif step.technologiable_type == "Algorithms::Algorithm" %>
        <p class="text-xl font-bold hover:text-gray-700">Included Algorithm:</p>
      <% elsif step.technologiable_type == "CheatSheets::CheatSheet" %>
        <p class="text-xl font-bold hover:text-gray-700">Included Cheat Sheet:</p>
      <% elsif step.technologiable_type == "CheatSheetGroups::CheatSheetGroup" %>
        <p class="text-xl font-bold hover:text-gray-700">Included Cheat Sheet Group:</p>
      <% end %>
    </div>

    <% binding.pry %>
    <!--      asynch_loader seaction -->
    <div class="container-inner-technology"
         data-controller="technology_asynch_rendering"
         data-target="technology_asynch_rendering.container"
         data-technology_asynch_rendering-technologiable-type-value="<%= step.technologiable_type %>"
         data-technology_asynch_rendering-technologiable-id-value="<%= step.technologiable_id %>"
    >

      <!-- spinner-->
      <div class="inner-technology-loading-indicator" data-target="technology_asynch_rendering.loadingIndicator" style="display: none;">
        <%= render "shared/small_ui_elements/loading_indicator" %>
      </div>

      <!--  request failed card -->
      <div data-target="technology_asynch_rendering.retryCard" style="display: none;"
           class="max-w-6xl p-6 bg-white border border-gray-200 rounded-lg shadow dark:bg-gray-800 dark:border-gray-700">
        <a href="#">
          <h5 class="mb-2 text-2xl font-bold tracking-tight text-gray-900 dark:text-white">Something went wrong</h5>
        </a>
        <p class="mb-3 font-normal text-gray-700 dark:text-gray-400">Use the following button to reload content.</p>

        <div class="flex justify-center">
          <div class="block space-y-4 md:flex md:space-y-0 md:space-x-4 ">
            <button data-action="click->technology_asynch_rendering#retryLoad"
                    class="relative inline-flex items-center justify-center p-0.5 mb-2 mr-2 overflow-hidden text-sm font-medium text-gray-900 rounded-lg group bg-gradient-to-br from-purple-600 to-blue-500 group-hover:from-purple-600 group-hover:to-blue-500 hover:text-white dark:text-white focus:ring-4 focus:outline-none focus:ring-blue-300 dark:focus:ring-blue-800"
                    type="button">
                <span class="relative px-5 py-2.5 transition-all ease-in duration-75 bg-white dark:bg-gray-900 rounded-md group-hover:bg-opacity-0">
                  Reload
                </span>
            </button>
          </div>
        </div>
      </div>

    </div>
  </div>
</div>

<% if step.step_finish_check.present? %>
  <div class="break-words step-finish-check-section" id="step-finish-check-<%= step.uuid %>">
    <hr class="w-48 h-1 mx-auto my-4 bg-gray-100 border-0 rounded md:my-10 dark:bg-gray-700">
    <div class="text-center col-span-6 sm:col-span-3">
      <p class="text-xl font-bold hover:text-gray-700 hover:underline hover:text-blue-600"># Step finish check:</p>
    </div>
    <div class="step-finish-check-content bg-white rounded-xl p-5">
      <%= step.step_finish_check.html_safe %>
    </div>
  </div>
  <br>
<% end %>

<% if step.sources.present? %>
  <div class="break-words step-sources-section" id="step-sources-<%= step.uuid %>">
    <hr class="w-48 h-1 mx-auto my-4 bg-gray-100 border-0 rounded md:my-10 dark:bg-gray-700">
    <div class="text-center col-span-6 sm:col-span-3">
      <p class="text-xl font-bold hover:text-gray-700 hover:underline hover:text-blue-600"># Sources:</p>
    </div>
    <div class="step-sources-content bg-white rounded-xl p-5">
      <%= step.sources.html_safe %>
    </div>
  </div>
  <br>
<% end %>

<% if step.additional_information.present? %>
  <div class="break-words step-additional-information-section" id="step-additional-information-<%= step.uuid %>">
    <hr class="w-48 h-1 mx-auto my-4 bg-gray-100 border-0 rounded md:my-10 dark:bg-gray-700">
    <div class="text-center col-span-6 sm:col-span-3">
      <p class="text-xl font-bold hover:text-gray-700 hover:underline hover:text-blue-600"># Additional information:</p>
    </div>
    <div class="step-additional-information-content bg-white rounded-xl p-5">
      <%= step.additional_information.html_safe %>
    </div>
  </div>
  <br>
<% end %>
