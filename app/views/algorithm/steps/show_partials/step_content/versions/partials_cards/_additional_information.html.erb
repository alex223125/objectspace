<div class="break-words step-additional-information-section mt-10 mb-14" id="step-additional-information-<%= step.uuid %>">

  <!-- Horizontal Connector Mapping Line -->
  <div class="relative flex py-6 items-center max-w-3xl mx-auto">
    <div class="flex-grow border-t-2 border-slate-100"></div>
    <span class="flex-shrink mx-4 text-purple-600 bg-purple-50 px-3 py-1 rounded-full text-[10px] tracking-widest font-black uppercase border border-purple-100/60 shadow-sm animate-pulse">⚡ Intel Expansion</span>
    <div class="flex-grow border-t-2 border-slate-100"></div>
  </div>

  <!-- SECTION HEADER TITLE -->
  <div class="text-center mb-6">
    <p class="text-xl font-black text-slate-800 tracking-wide hover:text-blue-600 hover:underline transition-colors cursor-default">
      # Additional information:
    </p>
  </div>

  <!-- MAXIMALIST MASTER HIGH-LEVEL GRAPHICAL PLATFORM -->
  <div class="max-w-3xl mx-auto my-6 p-8 bg-gradient-to-b from-white via-slate-50/40 to-slate-100/70 border-[3px] border-slate-200 rounded-[48px] shadow-xl relative overflow-hidden ring-8 ring-slate-100/50 group">

    <!-- Retro Handheld LCD Matrix Lens Film -->
    <div class="absolute inset-0 opacity-[0.04] pointer-events-none mix-blend-overlay bg-[linear-gradient(rgba(15,23,42,1)_50%,transparent_50%)] bg-[size:100%_4px]"></div>

    <!-- Multi-Layer Vector Data Matrix Grid Backing -->
    <div class="absolute inset-0 opacity-[0.03] pointer-events-none" style="background-image: radial-gradient(#334155 1px, transparent 1px); background-size: 10px 10px;"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-96 h-96 bg-gradient-to-tr from-purple-200/20 via-indigo-200/20 to-amber-200/10 rounded-full blur-3xl animate-[pulse_5s_ease-in-out_infinite]"></div>

    <!-- MAIN ISOMETRIC BLUEPRINT FIELD -->
    <div class="flex flex-col items-center justify-center py-6 relative z-10">

      <div class="relative w-full h-48 flex items-center justify-center scale-95 sm:scale-100">

        <!-- Deep Baseline Ground Shadow Anchor -->
        <div class="absolute w-72 h-10 bg-slate-300/40 rounded-full transform translate-y-20 blur-md group-hover:scale-110 transition-transform duration-700"></div>

        <!-- COMPLEX SVG TOPOLOGY PIPELINE INTEGRATOR (tailwindcss-rails 2.0.21 Safe Coordinate Injections) -->
        <div class="absolute inset-0 opacity-85 pointer-events-none [transform:rotateX(62deg)_rotateZ(12deg)] scale-110">
          <svg class="w-full h-full" viewBox="0 0 384 192">
            <!-- Main Trunk Paths -->
            <path d="M 30 120 L 110 60 M 110 60 L 192 30 M 192 30 L 274 60 M 274 60 L 354 120" stroke="url(#additional-glow-grad)" stroke-width="3" stroke-dasharray="6,4" fill="none" class="animate-[pulse_2s_infinite]"></path>
            <!-- Sub-Branching Decision Links -->
            <path d="M 110 60 L 192 95 M 192 30 L 192 95 M 192 95 L 274 60 M 110 60 L 110 140 M 274 60 L 274 140 M 192 95 L 192 160" stroke="url(#additional-sub-grad)" stroke-width="2" stroke-dasharray="4,4" fill="none"></path>
            <defs>
              <linearGradient id="additional-glow-grad" x1="0%" y1="0%" x2="100%" y2="0%">
                <stop offset="0%" stop-color="#a78bfa"></stop>
                <stop offset="40%" stop-color="#fbbf24"></stop>
                <stop offset="70%" stop-color="#38bdf8"></stop>
                <stop offset="100%" stop-color="#34d399"></stop>
              </linearGradient>
              <linearGradient id="additional-sub-grad" x1="0%" y1="100%" x2="100%" y2="0%">
                <stop offset="0%" stop-color="#c084fc"></stop>
                <stop offset="100%" stop-color="#22d3ee"></stop>
              </linearGradient>
            </defs>
          </svg>
        </div>

        <!-- ==================== 7-ELEMENT COHESIVE SYSTEM BLUEPRINT COLLAGE ==================== -->

        <!-- NODE 1: BASE DATA INGESTION (Far Left Lower Initial Parameters) -->
        <div class="absolute [transform:rotateX(60deg)_rotateZ(45deg)] -translate-x-36 translate-y-12 animate-[pulse_3s_infinite] flex flex-col -space-y-4">
          <div class="w-8 h-8 bg-purple-50 border-2 border-purple-400 rounded-lg shadow-md flex items-center justify-center text-xs select-none">📜</div>
          <div class="w-8 h-8 bg-purple-100/40 border border-purple-300 rounded-lg"></div>
        </div>

        <!-- NODE 2: STRATEGIC STEERING (Left Mid-Level Branch) -->
        <div class="absolute w-9 h-9 bg-indigo-50 border-2 border-indigo-400 rounded-xl [transform:rotateX(60deg)_rotateZ(45deg)] -translate-x-24 -translate-y-2 shadow-md animate-[bounce_3.8s_ease-in-out_infinite] flex items-center justify-center">
          <span class="[transform:rotateZ(-45deg)_rotateX(30deg)] text-xs filter drop-shadow-sm select-none">🧭</span>
        </div>

        <!-- NODE 3: ACCESS PRIVILEGE TOKEN KEY (Upper Left Branch Elevation Anchor) -->
        <div class="absolute w-10 h-10 bg-sky-50 border-2 border-sky-400 rounded-[14px] [transform:rotateX(60deg)_rotateZ(45deg)] -translate-x-14 -translate-y-16 shadow-md animate-[bounce_3.2s_ease-in-out_infinite] flex items-center justify-center">
          <span class="[transform:rotateZ(-45deg)_rotateX(30deg)] text-xs select-none animate-pulse">🔑</span>
        </div>

        <!-- NODE 4: BONUS INTEL SPARK BLOCK (Center Core - Loaded with Sparkles ✨) -->
        <div class="absolute w-16 h-16 bg-purple-50 border-[3px] border-purple-400 shadow-2xl shadow-purple-300/40 ring-[6px] ring-purple-200/50 rounded-[24px] [transform:rotateX(60deg)_rotateZ(45deg)] -translate-y-6 animate-[bounce_2.5s_ease-in-out_infinite] flex items-center justify-center">
          <!-- Core Energy Interceptor Radar Wave Ring -->
          <div class="absolute inset-0 rounded-[20px] bg-purple-400/20 opacity-0 animate-ping"></div>
          <span class="[transform:rotateZ(-45deg)_rotateX(30deg)] text-2xl filter drop-shadow-md select-none">✨</span>
        </div>

        <!-- NODE 5: RELATIONAL TOPOLOGY TREE (Upper Right Branch Elevation Anchor) -->
        <div class="absolute w-10 h-10 bg-amber-50 border-2 border-amber-400 rounded-[14px] [transform:rotateX(60deg)_rotateZ(45deg)] translate-x-14 -translate-y-16 shadow-md animate-[bounce_3.4s_ease-in-out_infinite] flex items-center justify-center">
          <span class="[transform:rotateZ(-45deg)_rotateX(30deg)] text-xs select-none">🖧</span>
        </div>

        <!-- NODE 6: LONG-RANGE ANALYSIS HORIZON (Right Mid-Level Branch) -->
        <div class="absolute w-9 h-9 bg-cyan-50 border-2 border-cyan-400 rounded-xl [transform:rotateX(60deg)_rotateZ(45deg)] translate-x-24 -translate-y-2 shadow-md animate-[bounce_3.6s_ease-in-out_infinite] flex items-center justify-center">
          <span class="[transform:rotateZ(-45deg)_rotateX(30deg)] text-xs filter drop-shadow-sm select-none">🔭</span>
        </div>

        <!-- NODE 7: COMPREHENSIVE RECON PACK (Far Right Lower Terminal Success Output) -->
        <div class="absolute [transform:rotateX(60deg)_rotateZ(45deg)] translate-x-36 translate-y-12 animate-[pulse_2.2s_infinite] flex flex-col -space-y-4">
          <div class="w-8 h-8 bg-emerald-50 border-2 border-emerald-400 rounded-lg shadow-md flex items-center justify-center text-xs font-black text-emerald-600 select-none">✓</div>
          <div class="w-8 h-8 bg-emerald-100/50 border border-emerald-300 rounded-lg shadow-inner"></div>
        </div>

        <!-- ==================== ANIMATED HUD PERIPHERALS & SYNCHRONIZATION ORBITS ==================== -->

        <!-- Double Concentric Dotted Vector Orbit Tracks -->
        <div class="absolute w-56 h-56 border-2 border-dotted border-purple-400/30 rounded-full [transform:rotateX(65deg)_rotateZ(25deg)] -translate-y-2 animate-spin"></div>
        <div class="absolute w-44 h-44 border border-dashed border-amber-400/20 rounded-full [transform:rotateX(65deg)_rotateZ(-35deg)] -translate-y-2 animate-spin [animation-direction:reverse]"></div>

        <!-- Floating Operational Validation Param Flags -->
        <div class="absolute top-0 left-12 bg-purple-50 border border-purple-200 text-purple-600 font-black text-[8px] px-1.5 py-0.5 rounded animate-bounce shadow-sm">BONUS_INTEL</div>
        <div class="absolute bottom-0 right-12 bg-emerald-50 border border-emerald-200 text-emerald-600 font-black text-[8px] px-1.5 py-0.5 rounded animate-pulse shadow-sm">SYNC_OK</div>

      </div>

    </div>

    <!-- HARDWARE CONTROL STATUS INFOBAR FOOTER -->
    <div class="text-center mt-8 space-y-2 w-full max-w-sm mx-auto">
      <div class="flex items-center justify-center space-x-2">
        <span class="text-[9px] font-black uppercase tracking-widest text-purple-700 bg-purple-100 border border-purple-300 px-2.5 py-0.5 rounded-md shadow-sm animate-pulse">
          🌐 INTEL_EXPANSION_STABLE
        </span>
        <span class="text-slate-400 font-bold text-xs">//</span>
        <span class="text-[9px] font-black uppercase tracking-widest text-slate-500 bg-slate-200/80 px-2 py-0.5 rounded-md shadow-inner">
          PACK LOADED
        </span>
      </div>

      <!-- Live Thread Status Feed Tracker -->
      <p class="text-[11px] font-bold text-slate-500 leading-normal max-w-xs mx-auto tracking-wide">
        Injecting auxiliary documentation nodes... Optimizing reference paths. Deep context parsing finalized!
      </p>
    </div>

  </div>

  <!-- ORIGINAL DYNAMIC CONTENT BOX -->
  <div class="step-additional-information-content bg-white rounded-xl p-5">
    <%= step.additional_information.html_safe %>
  </div>
</div>
