<%= simple_form_for(@algorithm, url: simple_algorithm_version_creation_path(algorithm_id: @algorithm.id,
                                                                            wizard_id: step.to_s,
                                                                            algorithm_version_id: @algorithm_version.slug), method: :put,
                    html: { data: { turbo: false }, id: "nested-steps-form-root", class: "max-w-5xl mx-auto space-y-6" }) do |f| %>

  <!-- Renders custom server-side base arrays validation error block if step count is zero -->
  <% if @algorithm_version.errors[:base].present? %>
    <div class="p-4 text-sm text-red-800 bg-red-50 rounded-xl border-2 border-red-200 font-medium">
      ⚠️ <%= @algorithm_version.errors[:base].first %>
    </div>
  <% end %>

  <div class="bg-white border border-gray-200 p-6 rounded-2xl shadow-sm">
    <h2 class="text-xl font-bold text-gray-900 mb-2">Step 3: Build Steps Grid Layout</h2>
    <p class="text-xs text-gray-500 mb-6">Every algorithm version requires at least 1 functional active step subnode in memory to persist.</p>

    <!-- INSERT THE COMPACT RADIO PICKER CARDS MATRIX DESIGNED EARLIER -->
    <%= render "algorithm/simple_algorithm_version_creation/partials/nested_steps_interface_builder", form: f %>
  </div>


  <div class="flex justify-between items-center">
    <%= link_to "⬅ Back to Story", previous_wizard_path(version_id: @algorithm_version.slug), class: "text-sm font-semibold text-gray-500 hover:text-gray-900" %>
    <%= f.button :submit, "Review Global Blueprint ➔", class: "bg-indigo-600 text-white font-bold px-5 py-2.5 rounded-xl hover:bg-indigo-700 transition" %>
  </div>
<% end %>