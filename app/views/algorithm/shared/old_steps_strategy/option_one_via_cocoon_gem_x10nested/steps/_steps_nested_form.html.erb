<hr class="w-48 h-1 mx-auto my-4 bg-gray-100 border-0 rounded md:my-10 dark:bg-gray-700">

<!--<h2 class="text-2xl font-bold leading-7 text-gray-900 sm:truncate sm:text-3xl sm:tracking-tight text-center">Steps</h2>-->

<div class="col-span-6 sm:col-span-3">
  <p class="text-xl font-bold hover:text-gray-700">Steps:</p>
  <p class="mt-2 text-sm text-gray-500">Here you can add examples how to use the method on practice with different cases and scenarios. Click on substep and move up or down to change position in the substeps list.</p>
  <%#= link_to "Add new usage example", units_path, class: "inline-flex justify-center rounded-md border border-transparent bg-indigo-600 py-2 px-4 text-sm font-medium text-white shadow-sm hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2" %>
</div>
<br>

<div>

  <div data-controller="steps_drag remote_select_instruction algorithm_step_type_select"
       data-drag-url="/todos/:id/move"
       data-target="remote_select_instruction.stepsArea steps_drag.stepsArea"
       data-remote_select_instruction-select-type-value="wrapper_step_addition"
  >

    <%#= form.fields_for :steps, algorithm_version.steps.order(position: :asc) do |t| %>
    <%= form.fields_for :steps do |t| %>
        <%# @todos.order(position: :asc).each do |todo| %>
<!--      <div data-id="<%#= t.object.id %>">-->
      <%#= render "algorithm/shared/partials/steps/step_fields", :f => t %>
          <%= render "algorithm/shared/partials/steps/regular_step_fields", :f => t %>

          <%= render "algorithm/shared/partials/steps/wrapper_step_fields", :f => t %>
<!--      </div>-->
<!--          <div data-id="<%#= todo.id %>" class="card card-body mb-4">-->
            <%#= todo.description %>
<!--          </div>-->
        <%# end %>
    <% end %>


<!--    <div data-controller="algorithm_step_type_select">-->

      <!--    Option 1.Regular step-->
      <div>
        <%= link_to_add_association "Add Step (regular)", form,
                                    :steps,
                                    style: "display:none;",
                                    partial: 'algorithm/shared/partials/steps/regular_step_fields',
                                    class: "nodraggablesteps inline-flex justify-center rounded-md border border-transparent bg-indigo-600 py-2 px-4 text-sm font-medium text-white shadow-sm hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2",
                                    data: {target: "algorithm_step_type_select.addRegularStepOriginalButton"}
        %>
      </div>

      <!--    Option 2.Wrapper step-->
      <div>
        <%= link_to_add_association "Add Step (wrapper)", form,
                                    :steps,
                                    style: "display:none;",
                                    partial: 'algorithm/shared/partials/steps/wrapper_step_fields',
                                    class: "nodraggablesteps inline-flex justify-center rounded-md border border-transparent bg-indigo-600 py-2 px-4 text-sm font-medium text-white shadow-sm hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2",
                                    data: {target: "algorithm_step_type_select.addWrapperStepOriginalButton"}
        %>
      </div>

      <%= render "algorithm/shared/partials/shared/step_type_select_modal" %>


    <%= render "shared/technologies_search/modal", :form => form, :type => "wrapper_step_addition" %>



  </div>

  <!--  <div data-controller="sortable" data-sortable-url="/recipes/:recipe_id/steps/:id/step_position">-->
    <%#= f.fields_for :steps, @recipe.steps.order(position: :asc) do |step| %>
<!--      <div data-id="<%#= step.object.id %>">-->
        <%#= step.text_area :description %>
<!--      </div>-->
    <%# end %>
<!--  </div>-->


</div>

<hr class="w-48 h-1 mx-auto my-4 bg-gray-100 border-0 rounded md:my-10 dark:bg-gray-700">


