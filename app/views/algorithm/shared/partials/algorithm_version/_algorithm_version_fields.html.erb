<div class="col-span-6 sm:col-span-3">

  <!-- ALGORITHM BLUEPRINT COVER UPLOAD COMPONENT MODULE -->
  <div class="space-y-2 bg-slate-50/50 p-5 rounded-2xl border border-slate-200 shadow-sm transition-all duration-300 hover:border-cyan-500/20">
    <div class="flex items-center justify-between select-none">
      <%= f.label :cover_image, "Blueprint Cover Canvas Asset", class: "block text-xs font-mono font-black uppercase tracking-wider text-slate-700" %>
      <span class="text-[9px] font-mono text-cyan-600 uppercase tracking-widest bg-cyan-50 border border-cyan-200/50 px-2 py-0.5 rounded-md font-bold">
      Asset // Multipart File
    </span>
    </div>
    <p class="text-xs text-slate-400 font-medium">Upload a design matrix cover image to bind onto active registry cards and thumbnails.</p>

    <div class="relative mt-2 group/upload border-2 border-dashed border-slate-200 bg-white hover:border-cyan-500/50 rounded-xl p-6 transition-all flex flex-col items-center justify-center text-center cursor-pointer">
      <!-- Active Rails File Field Wrapper mapping parameters -->
      <%= f.file_field :cover_image, class: "absolute inset-0 w-full h-full opacity-0 cursor-pointer z-20" %>

      <div class="space-y-2 relative z-10 pointer-events-none flex flex-col items-center select-none">
        <div class="w-10 h-10 bg-slate-50 border border-slate-200 rounded-xl flex items-center justify-center text-lg text-slate-500 transition-transform group-hover/upload:scale-105">
          🖼️
        </div>
        <div>
          <p class="text-xs font-sans font-bold text-slate-800">Click to choose or drop blueprint file</p>
          <p class="text-[10px] font-mono text-slate-400 uppercase">Formats: PNG, JPG, WEBP // Max 4MB Capacity</p>
        </div>
      </div>
    </div>
  </div>


  <%= f.label "Version title", class: "block text-sm font-medium text-gray-700" %>
  <div class="bg-yellow-50 border border-yellow-400 rounded text-yellow-800 text-sm p-4 flex items-start">
    <div>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-2" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"></path>
      </svg>
    </div>
    <div class="w-full">
      <!--<p>-->
      <!--  <span class="font-bold">Error:</span>-->
      <!--  Lorem ipsum dolor sit amet consectetur adipisicing elit. Iusto quos-->
      <!--  exercitationem, voluptate eos reprehenderit fugit assumenda illo error-->
      <!--  facere consequuntur perferendis asperiores dolor et itaque.-->
      <!--</p>-->

      <p>Each method can have multiple versions of the same instruction.</p>
      <p> Use this field if you plan to create multiple versions of same instruction for different contexts.</p>
      <p>For example you might have in mind tutorial about how to install Ruby on Rails on your Desktop</p>
      <p>Possible versions of the tutorial will be:</p>
      <ul class="list-disc">
        <li>Install Ruby on Rails on Ubuntu 16</li>
        <li>Install Ruby on Rails on Ubuntu 18</li>
        <li>Install Ruby on Rails on Ubuntu 20</li>
        <!-- ... -->
      </ul>
      <p>You can also use less specific versions</p>
      <ul class="list-disc">
        <li>Install Ruby on Rails on Ubuntu</li>
        <li>Install Ruby on Rails on macOS</li>
        <li>Install Ruby on Rails on Windows</li>
        <!-- ... -->
      </ul>

      <p>At the moment you can pick one and add only one version of instruction.</p>
      <p>You will be able modify current and add new versions of instruction after creation of current version.</p>
    </div>
    <div>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </div>
  </div>
  <%= f.input_field :title, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
</div>
<br>

<div class="mb-6">
  <!-- Main Label -->
  <label class="block text-base font-semibold text-gray-900 mb-3">
    Interactivity Type
  </label>

  <!-- 3-Column Card Grid Container -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-4">

    <%= f.collection_radio_buttons :interactivity_type_id,
                                   AlgorithmVersions::InteractivityTypes.to_select,
                                   :last, :first,
                                   item_wrapper_tag: false do |builder| %>

      <% unique_id = "interactivity_type_#{builder.value.to_s.parameterize}" %>

      <div class="relative flex flex-col">
        <!-- The Native Input Overlay Sibling -->
        <%= builder.radio_button(id: unique_id, class: "peer absolute opacity-0 w-full h-full top-0 left-0 cursor-pointer z-10") %>

        <!-- THE CORRECTION IS APPLIED HERE: Added peer-checked:[&_.fake-box]: variants on the parent to cleanly trigger internal child components -->
        <label for="<%= unique_id %>" class="w-full flex flex-col p-5 bg-white border-4 border-gray-200 rounded-xl pointer-events-none shadow-sm transition-all duration-150
                     peer-hover:bg-indigo-50/30 peer-hover:border-indigo-300/60
                     peer-active:scale-95
                     peer-checked:border-indigo-600 peer-checked:shadow-lg peer-checked:shadow-indigo-600/20
                     peer-checked:[&_.fake-box]:border-indigo-600 peer-checked:[&_.fake-box]:bg-indigo-600 peer-checked:[&_.fake-box]:ring-4 peer-checked:[&_.fake-box]:ring-indigo-100/70
                     peer-checked:[&_.check-svg]:scale-100 peer-checked:[&_.check-svg]:opacity-100">

          <!-- Graphical Emoji Representation & Indicator Area -->
          <div class="text-2xl mb-2 flex items-center justify-between">
            <div>
              <% case builder.value %>
              <% when AlgorithmVersions::InteractivityTypes[:simple_static_algorithm] %>
                <span class="inline-flex items-center justify-center p-2 bg-amber-50 text-amber-600 rounded-lg transition-colors duration-150 peer-checked:bg-indigo-100 peer-checked:text-indigo-700">📝</span>
              <% when AlgorithmVersions::InteractivityTypes[:simple_interactive_algorithm] %>
                <span class="inline-flex items-center justify-center p-2 bg-emerald-50 text-emerald-600 rounded-lg transition-colors duration-150 peer-checked:bg-indigo-100 peer-checked:text-indigo-700">📄</span>
              <% when AlgorithmVersions::InteractivityTypes[:some_type_three] %>
                <span class="inline-flex items-center justify-center p-2 bg-rose-50 text-rose-600 rounded-lg transition-colors duration-150 peer-checked:bg-indigo-100 peer-checked:text-indigo-700">⚡</span>
              <% else %>
                <span class="inline-flex items-center justify-center p-2 bg-gray-50 text-gray-600 rounded-lg">❓</span>
              <% end %>
            </div>

            <!-- FAKE CHECKBOX INPUT: Controlled via the parent label's child-selector classes using the target 'fake-box' class -->
            <div class="fake-box h-5 w-5 rounded-md border border-gray-300 flex items-center justify-center transition-all duration-200 shadow-sm">

              <!-- THE VISUAL CHECKMARK SELECTION VECTOR: Targeted via the 'check-svg' class name descriptor -->
              <svg class="check-svg h-3.5 w-3.5 text-white transition-all duration-200 transform scale-0 opacity-0"
                   xmlns="http://w3.org"
                   fill="none"
                   viewBox="0 0 24 24"
                   stroke-width="3"
                   stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
            </div>
          </div>

          <!-- Title -->
          <span class="block font-bold text-gray-900 text-sm tracking-tight transition-colors duration-150">
            <%= AlgorithmVersions::InteractivityTypes.description(builder.value) %>
          </span>

          <!-- Contextual Descriptions -->
          <p class="block text-xs text-gray-500 mt-1.5 leading-relaxed transition-colors duration-150">
            <% case builder.value %>
            <% when AlgorithmVersions::InteractivityTypes[:simple_static_algorithm] %>
              Processes logic serverside. Best for standard linear calculation workflows.
            <% when AlgorithmVersions::InteractivityTypes[:simple_interactive_algorithm] %>
              Renders configuration rules on a single viewport canvas simultaneously.
            <% when AlgorithmVersions::InteractivityTypes[:some_type_three] %>
              Employs progressive layout layers using contextual wizard animations.
            <% end %>
          </p>

        </label>
      </div>
    <% end %>

  </div>

  <!-- Render Simple Form Validation Errors Contextually underneath -->
  <%= f.error :interactivity_type_id, class: "mt-2 text-sm text-red-600" %>
</div>

<div class="col-span-6 sm:col-span-3" data-controller="unit_instruction_tinymce">
  <%= f.label "Description (optional)", class: "block text-sm font-medium text-gray-700" %>
  <%= f.hint 'Use this place to prepare users for using algorithm', class: "mt-2 text-sm text-gray-500" %>
  <%= f.input_field :description,
                    placeholder: "Template of description goes here (goals, principles,intro)",
                    data: { target: 'unit_instruction_tinymce.field' } %>
</div>
<br>

<div class="col-span-6 sm:col-span-3" data-controller="unit_solves_the_problem_tinymce">
  <%= f.label "Problem (optional)", class: "block text-sm font-medium text-gray-700" %>
  <%= f.hint 'Describe what problem or problems this method solves.', class: "mt-2 text-sm text-gray-500" %>
  <%= f.input_field :solves_the_problem,
                    placeholder: "Using this algorithm we can build RoR app.
                    If this instruction solves specific task or problem, you can desribe in this field.
                    For example: 'This algorithm solves problem of step-by-step creating sorting algorithm for binaies trees.'",
                    data: { target: 'unit_solves_the_problem_tinymce.field' } %>
</div>
<br>

<div class="col-span-6 sm:col-span-3" data-controller="unit_sources_tinymce">
  <%= f.label "Sources (optional)", class: "block text-sm font-medium text-gray-700" %>
  <%= f.hint 'If your method based on any credible sources of information you can add it here.', class: "mt-2 text-sm text-gray-500" %>
  <%= f.input_field :sources, data: { target: 'unit_sources_tinymce.field' } %>
</div>
<br>

<div class="col-span-6 sm:col-span-3" data-controller="unit_additional_information_tinymce">
  <%= f.label "Additional information (optional)", class: "block text-sm font-medium text-gray-700" %>
  <%= f.hint 'If you have something to add which does not fit in any of the above category you can add it here..', class: "mt-2 text-sm text-gray-500" %>
  <%= f.input_field :additional_information, data: { target: 'unit_additional_information_tinymce.field' } %>
</div>

<%= render "algorithm/shared/partials/algorithm_version/introduction_step_fields", :form => f %>
