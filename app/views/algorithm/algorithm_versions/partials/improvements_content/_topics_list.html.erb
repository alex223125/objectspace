<!-- app/views/algorithm/algorithm_versions/partials/improvements_content/_topics_list.html.erb -->

<!-- UNIFIED ENCYCLOPEDIA QUEST LOG WORKSPACE WRAPPER -->
<div class="p-6 rounded-2xl bg-amber-50/60 border-2 border-amber-200/80 shadow-xl backdrop-blur-md mb-6 relative overflow-hidden ring-1 ring-amber-100/50">

  <!-- Subtle Scholar Notebook Margin Accent Lines -->
  <div class="absolute left-4 top-0 bottom-0 w-px bg-amber-200/40 pointer-events-none"></div>
  <div class="absolute left-[18px] top-0 bottom-0 w-px bg-rose-200/30 pointer-events-none"></div>

  <div data-controller="improvements_infinite_scroll" class="pl-4">

    <!-- Quest Chapter Header Decorator -->
    <div class="flex items-center gap-2 mb-4 pb-3 border-b border-dashed border-amber-300/60 select-none">
      <span class="text-base text-amber-600 animate-pulse">📜</span>
      <h3 class="text-xs font-serif font-bold text-amber-800 uppercase tracking-widest">
        Active Research Objective // Encyclopedia Log Feed
      </h3>
    </div>

    <div class="improvements-items space-y-4">

      <!-- 1. MODERN HOTWIRE ASYNC CONTENT INJECTION ENTRY TARGET CONTAINER -->
      <div data-improvements_infinite_scroll-target="entries" class="space-y-3">
        <div class="p-8 text-center border-2 border-dashed border-amber-200 rounded-xl bg-white/80 text-xs font-serif italic text-amber-700/70 tracking-wide shadow-inner animate-pulse flex flex-col items-center justify-center gap-2">
          <div>🖋️ Unrolling ancient manuscripts & compiling knowledge maps...</div>
          <span class="text-[9px] font-sans font-bold not-italic tracking-widest text-amber-500 uppercase">[ RETRIEVING_ARCHIVAL_DATA_SETS ]</span>
        </div>
      </div>

      <!-- 2. QUEST SYSTEM INTERSECTION OBSERVER DETECTOR LOADING BAR -->
      <div data-improvements_infinite_scroll-target="pagination"
           class="w-full py-4 bg-white/90 border-2 border-amber-200 rounded-xl flex items-center justify-center gap-3 text-xs font-sans font-bold text-amber-800 uppercase tracking-wider transition-all hover:border-amber-400 hover:shadow-md select-none mt-5 shadow-sm group cursor-pointer">
        <div class="relative w-5 h-5 flex items-center justify-center text-amber-600">
          <span class="absolute inline-flex h-full w-full rounded-full bg-amber-500/20 opacity-75 animate-ping"></span>
          <span class="inline-block animate-spin text-sm group-hover:text-amber-500">🧭</span>
        </div>
        <span>Deciphering Next Chronicle Segment // Load More</span>
      </div>

    </div>
  </div>
</div>

<!-- ==================== NEW: BRIGHT ENCYCLOPEDIA QUEST ACTION PANEL ==================== -->
<div class="w-full p-6 bg-white/80 border-2 border-amber-200 rounded-2xl shadow-xl flex flex-col items-center justify-center text-center relative overflow-hidden mb-6 group transition-all duration-300 hover:border-amber-300 hover:shadow-2xl">
  <!-- Subtle background ambient design pattern -->
  <div class="absolute -right-6 -bottom-6 text-6xl opacity-10 select-none pointer-events-none group-hover:rotate-12 transition-transform duration-500">🖋️</div>

  <div class="relative z-10 max-w-sm space-y-4">
    <div class="space-y-1">
      <span class="text-[10px] font-sans font-black text-amber-600 tracking-widest uppercase block">// ARCHIVAL_EXPANSION_PROTOCOL</span>
      <h4 class="text-sm font-serif font-black text-amber-900 tracking-wide uppercase">Missing Crucial Analytical Insights?</h4>
      <p class="text-xs text-amber-800/70 font-medium">Contribute to the encyclopedia matrix ledger to unlock achievements and guide incoming junior scholars.</p>
    </div>

    <!-- The Gamified Submission Trigger Button -->
    <div class="relative inline-block mt-2">
      <!-- Glow Ring Effect underneath button -->
      <div class="absolute -inset-1 bg-gradient-to-r from-amber-500 via-orange-400 to-yellow-500 rounded-xl blur opacity-30 group-hover:opacity-60 transition duration-300"></div>

      <!-- The Gamified Submission Trigger Link Component -->
      <div class="relative inline-block mt-2">
        <!-- Glow Ring Effect underneath button -->
        <div class="absolute -inset-1 bg-gradient-to-r from-amber-500 via-orange-400 to-yellow-500 rounded-xl blur opacity-30 group-hover:opacity-60 transition duration-300"></div>

        <!-- Direct link to standard ImprovementsController passing target parameters -->
        <%= link_to new_improvement_path(
                      algorithm_version_id: @algorithm_version&.slug || params[:algorithm_id],
                      return_to: "#{request.base_url}#{request.path}?open_tab=improvements"
                    ),
                    class: "relative inline-flex items-center justify-center px-8 py-3.5 bg-gradient-to-r from-amber-500 to-orange-500 text-white font-sans font-black text-xs uppercase tracking-widest rounded-xl shadow-lg border border-amber-300/40 hover:border-white transform active:scale-95 transition-all duration-150 cursor-pointer no-underline" do %>
          <span class="mr-2 text-sm">💡</span>
          <span>Initiate Improvement Quest</span>
          <span class="ml-3 inline-flex items-center px-2 py-0.5 rounded-full text-[9px] font-black bg-amber-950 text-yellow-300 border border-amber-400/30 shadow-inner">
            +50 XP
          </span>
        <% end %>
      </div>

    </div>
  </div>
</div>
<!-- ===================================================================================== -->

<!-- COMPASS & ARCHIVAL MATRIX TELEMETRY INDEX FOOTER -->
<div class="mt-4 flex flex-col sm:flex-row items-center justify-between text-[10px] text-amber-800/60 font-sans font-bold uppercase tracking-widest gap-2 pl-6 select-none">
  <div class="flex items-center gap-1.5">
    <span class="text-amber-600">📖</span> Codex Reference: <span class="text-amber-900/80 font-mono">0x9DA8CA16</span>
  </div>
  <div class="flex items-center gap-4">
    <span>Knowledge Engine: <span class="text-amber-900/80">Pagy // Searchkick</span></span>
    <span class="flex items-center gap-1">
      Quest Protocol: <span class="text-emerald-600 font-extrabold px-1.5 py-0.5 bg-emerald-50 rounded border border-emerald-200">✓ Continuous Sync</span>
    </span>
  </div>
</div>

