<div class="w-full max-w-screen-xl mx-auto px-6 py-4">
  <div class="bg-white border border-slate-200/80 rounded-3xl p-6 shadow-sm space-y-6">

    <!-- 16:9 COMPACT HORIZONTAL COVER BANNER AT TOP -->
    <div class="w-full aspect-[21/7] max-h-[220px] bg-slate-50 border border-slate-200 rounded-2xl overflow-hidden shadow-inner relative group">

      <% if @algorithm_version.cover_image.attached? %>
        <!-- Render ActiveStorage attached image file -->
        <%= image_tag @algorithm_version.cover_image,
                      class: "w-full h-full object-cover transition-transform duration-700 group-hover:scale-[1.02]",
                      alt: @algorithm_version.title %>
        <div class="absolute inset-0 bg-gradient-to-b from-transparent via-slate-950/10 to-slate-950/50"></div>
        <!--                <span class="absolute bottom-4 left-4 bg-slate-900/90 text-white font-mono text-[10px] px-2.5 py-1 border border-slate-800 rounded font-black tracking-widest uppercase z-10">// ARCHIVAL_IMAGE_LOCKED</span>-->
      <% else %>
        <!-- Gamified abstract fallback canvas if image placeholder is empty -->
        <div class="w-full h-full bg-gradient-to-tr from-slate-50 via-cyan-500/[0.02] to-indigo-500/[0.04] flex flex-col items-center justify-center p-6 text-center select-none relative">
          <div class="absolute inset-0 border border-dashed border-slate-200/60 rounded-xl m-3 pointer-events-none"></div>
          <div class="space-y-1 text-slate-400 relative z-10 font-mono">
            <span class="text-2xl block animate-pulse">🗺️</span>
            <span class="text-[9px] font-black tracking-widest uppercase block text-slate-400/80">// MATRIX_IMAGE_FALLBACK</span>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>