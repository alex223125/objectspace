<!--Content area-->
<div class="max-w-6xl p-4 rounded-lg bg-gray-50 dark:bg-gray-800" data-controller="content_area" data-target="content_area.area">
  <!--center -->
  <div class="flex justify-between px-4 mx-auto max-w-screen-xl">
    <div class="w-full format-sm sm:format-base lg:format-lg format-blue dark:format-invert">
      <div class="mb-4 lg:mb-6 not-format p-3">
        <h1 class="break-words mb-4 text-3xl font-extrabold leading-tight text-gray-900 lg:mb-6 lg:text-4xl dark:text-white">
          <%= algorithm_version.title %>
        </h1>

        <%= render "algorithm/algorithm_versions/partials/algorithm_content/partials/notification_anchor" %>

        <!-- submenu -->
        <div class="mt-1 flex flex-col space-x-4 sm:mt-0 sm:flex-row sm:flex-wrap sm:space-x-6">
          <div class="mt-2 flex items-center text-sm">
            <%= render "algorithm/algorithm_versions/partials/algorithm_content/submenu/version_select_bar",
                       algorithm_version: algorithm_version %>
          </div>

          <div class="mt-2 flex items-center text-sm">
            <%= render "algorithm/algorithm_versions/partials/algorithm_content/submenu/copy_to_clipboard",
                       algorithm_version: algorithm_version %>
          </div>

          <% if current_user.try(:has_resource_modify_permissions?, algorithm_version.algorithm)  %>
            <div class="mt-2 flex items-center text-sm text-gray-500">
              <%= render "algorithm/algorithm_versions/partials/algorithm_content/submenu/options_dropdown",
                         algorithm_version: algorithm_version %>
            </div>
          <% end %>

          <div class="mt-2 flex items-center text-sm text-gray-500">
            <%= render "algorithm/algorithm_versions/partials/algorithm_content/submenu/execute_button",
                       algorithm_version: algorithm_version %>
          </div>

        </div>

        <div class="mt-1 flex flex-col space-x-4 sm:mt-0 sm:flex-row sm:flex-wrap sm:space-x-6">
          <div class="mt-2 flex items-center text-sm text-gray-500">
            <%= render "algorithm/shared/algorithm_tree_map/modal", algorithm_version: algorithm_version %>
          </div>

          <div class="mt-2 flex items-center text-sm text-gray-500">
            bookmark button
          </div>

          <div class="mt-2 flex items-center text-sm text-gray-500">
            <%= render "algorithm/algorithm_versions/partials/algorithm_content/qr_code_modal/modal",
                       algorithm_version: algorithm_version %>
          </div>
        </div>

        <%= render "algorithm/algorithm_versions/partials/algorithm_content/toc",
                   algorithm_version: algorithm_version, toc_type: "toc_for_regular_page"%>
        <br>

      </div>

      <% if algorithm_version.description.present? %>
        <div class="break-words description-section" id="algorithm-description-<%= algorithm_version.id %>">

          <hr class="w-48 h-1 mx-auto my-4 bg-gray-100 border-0 rounded md:my-10 dark:bg-gray-700">
          <div class="text-center col-span-6 sm:col-span-3">
            <p class="text-xl font-bold hover:text-gray-700"># Description:</p>
          </div>
          <div class="algorithm-description-content bg-white rounded-xl p-5">
            <%= algorithm_version.description.html_safe %>
          </div>

        </div>
        <br>
      <% end %>

      <% if algorithm_version.solves_the_problem.present? %>
        <div class="break-words solves-the-problem-section" id="algorithm-solves-the-problem-<%= algorithm_version.id %>">
          # Solves the problem:
          <%= algorithm_version.solves_the_problem.html_safe %>
        </div>
        <br>
      <% end %>


      <% if algorithm_version.additional_information.present? %>
        <div class="break-words additional-information-section" id="algorithm-additional-information-<%= algorithm_version.id %>">
          # Additional information:
          <%= algorithm_version.additional_information.html_safe %>
        </div>
        <br>
      <% end %>


      <div class="nodes" data-controller="attachment_preview">
        <%= render "algorithm/algorithm_versions/partials/algorithm_content/nodes/nodes", algorithm_version: algorithm_version %>

        <%= render "shared/attachment_preview/modal", entity: algorithm_version %>
      </div>

      <% if algorithm_version.sources.present? %>
        <div class="break-words sources-section" id="algorithm-sources-<%= algorithm_version.id %>">

          <hr class="w-48 h-1 mx-auto my-4 bg-gray-100 border-0 rounded md:my-10 dark:bg-gray-700">
          <div class="text-center col-span-6 sm:col-span-3">
            <p class="text-xl font-bold hover:text-gray-700"># Sources:</p>
          </div>

          <div class="algorithm-sources-content bg-white rounded-xl p-5">
            <%= algorithm_version.sources.html_safe %>
          </div>

        </div>
        <br>
      <% end %>


      <!-- contribute section -->
      <%= render "algorithm/algorithm_versions/partials/algorithm_content/add_example_section/main",
                 algorithm_version: algorithm_version %>
      <br>

      <%#= render "algorithm/algorithm_versions/partials/algorithm_content/add_improvement_section/list_of_improvements", algorithm_version: algorithm_version %>
<!--      <br>-->

      <%= render "algorithm/algorithm_versions/partials/algorithm_content/add_improvement_section/main",
                 algorithm_version: algorithm_version %>
      <br>
    </div>
  </div>
</div>

