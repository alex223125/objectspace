<!-- app/views/articles/article_versions/show.html.erb -->

<!-- 1. MAIN ASYNC CONTROLLER WORKSPACE WRAPPER -->
<!-- FIXED: Changed to underscore syntax to match your system naming metrics exactly -->
<div data-controller="async_improvements"
     data-async_improvements-endpoint-value="<%= entity_view_index_api_improvements_path(algorithm_version_id: @algorithm_version) %>"
     data-async_improvements-endpoint-post-value="<%= api_improvements_path(algorithm_version_id: @algorithm_version) %>"
     class="max-w-6xl mx-auto px-4 my-8">

  <!--  1.-->
  <%= render "algorithm/algorithm_versions/partials/algorithm_content/add_improvement_section/list_of_improvements" %>

  <!-- ==================== B. COLLAPSIBLE CONTRIBUTION DRAWER LAYER ==================== -->
  <!-- 2. COLLAPSIBLE FORM CONTROLLER MOUNT (Using your exact underscore identifier) -->
  <div data-controller="improvement_collapsible_form" class="w-full">

    <!-- Gamified Call-To-Action (CTA) Trigger Node -->
    <div data-improvement_collapsible_form-target="triggerContainer" class="flex flex-col items-center justify-center py-6 text-center transition-all duration-300">
      <div class="relative group">
        <!-- Animated ambient background glow -->
        <div class="absolute -inset-1 bg-gradient-to-r from-orange-500 via-amber-500 to-yellow-400 rounded-2xl blur opacity-75 group-hover:opacity-100 transition duration-300 animate-pulse"></div>

        <button type="button"
                data-action="click->improvement_collapsible_form#reveal"
                class="relative inline-flex items-center justify-center px-8 py-4 bg-gradient-to-r from-orange-500 to-amber-500 text-white font-black text-base rounded-xl shadow-2xl border-2 border-yellow-300/40 hover:border-white transform active:scale-95 transition-all duration-150 uppercase tracking-wider cursor-pointer group-hover:scale-105">
          <span class="mr-2">⚡</span>
          <span>Add Improvement</span>
          <span class="ml-4 inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-bold bg-gray-950 text-yellow-300 border border-yellow-400/30 shadow-md">
          +50 XP
        </span>
        </button>
      </div>
      <p class="mt-3 text-xs font-bold text-amber-600 dark:text-amber-500 uppercase tracking-wide animate-pulse">
        Click to expand initialization log matrix
      </p>
    </div>

    <!-- Hidden Drawer Content Panel -->
    <div data-improvement_collapsible_form-target="panel"
         class="hidden max-h-0 opacity-0 transform scale-95 transition-all duration-500 ease-out origin-top overflow-hidden">

      <div class="bg-white dark:bg-gray-950 border border-gray-200 dark:border-gray-800 rounded-2xl p-6 shadow-2xl relative mb-12">

        <!-- Drawer Close Trigger Handle -->
        <button type="button"
                data-action="click->improvement_collapsible_form#conceal"
                class="absolute top-4 right-4 font-mono text-[10px] font-bold uppercase bg-gray-100 hover:bg-gray-200 dark:bg-gray-900 dark:hover:bg-gray-800 text-gray-500 dark:text-gray-400 px-3 py-1.5 rounded-lg border border-gray-200/50 dark:border-gray-700 transition-colors cursor-pointer">
          ✕ Close Matrix
        </button>
        <br>

        <div class="mt-4">
          <!-- Gamified Header Bar Component -->
          <div class="w-full p-6 border border-gray-200 bg-gray-50 rounded-t-2xl dark:border-gray-700 dark:bg-gray-800/80 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 shadow-sm">
            <div>
              <div class="flex items-center gap-2">
                <span class="inline-flex items-center justify-center w-8 h-8 rounded-lg bg-cyan-500/10 text-cyan-500 font-bold text-lg animate-bounce">⬢</span>
                <h2 class="text-xl lg:text-2xl font-black text-gray-900 dark:text-white uppercase tracking-wide">Contribute Engine</h2>
              </div>
              <p class="text-sm text-gray-600 dark:text-gray-400 mt-1 font-medium">
                Help us make Encyclopedia better. Submit improvements.
              </p>
            </div>

            <!-- Gamification Profile Rank Component -->
            <div class="flex items-center space-x-3 bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 p-2.5 rounded-xl shadow-inner self-start sm:self-center">
              <div class="relative flex-shrink-0">
                <div class="absolute -inset-0.5 bg-gradient-to-r from-cyan-500 to-blue-500 rounded-full blur opacity-50"></div>
                <div class="relative w-10 h-10 rounded-full bg-gradient-to-tr from-cyan-500 to-blue-600 flex items-center justify-center text-white font-extrabold text-sm shadow-md">
                  Lvl 4
                </div>
              </div>
              <div>
                <div class="text-xs font-black text-gray-400 uppercase tracking-widest">Global Rank</div>
                <div class="text-sm font-bold text-gray-900 dark:text-cyan-400">Core Architect</div>
              </div>
            </div>
          </div>

          <!-- Main Layout Body Matrix Wrapper -->
          <div class="code-preview-wrapper">
            <div class="grid grid-cols-1 border-x border-b border-gray-200 dark:border-gray-700 rounded-b-2xl overflow-hidden bg-white dark:bg-gray-950 shadow-xl">

              <!-- Workspace Interactive Form Content Panel -->
              <div class="p-6 space-y-6">

                <!-- Server Response API Validation Exception Block Alert -->
                <div data-async-improvements-target="errorBlock" class="hidden p-4 text-xs font-mono text-red-800 bg-red-50 dark:bg-red-950/30 dark:text-red-400 rounded-xl border border-red-200 dark:border-red-900"></div>

                <!-- 3. NATIVE RAILS ASYNC FORM COMPONENT BUILDER -->
                <%= form_with(model: Improvements::Improvement.new,
                              url: api_improvements_path(algorithm_version_id: @algorithm_version),
                              id: "async-improvement-form",
                              data: { action: "submit->async_improvements#deployModification" },
                              html: { novalidate: true },
                              class: "space-y-4") do |form| %>

                  <!-- Title Entry Node Component Layout -->
                  <div>
                    <label for="improvement-title" class="block mb-1.5 text-xs font-black uppercase tracking-wider text-gray-500 dark:text-gray-400">
                      Improvement Title <span class="text-red-500">*</span>
                    </label>
                    <div class="relative">
                      <span class="absolute inset-y-0 left-0 flex items-center pl-3.5 text-gray-400 text-sm font-mono">#</span>

                      <%= form.text_field :title,
                                          id: "improvement-title",
                                          "data-async_improvements-target" => "titleInput", # FIXED: Hardcoded string literal preserves underscores
                                          class: "bg-gray-50 border border-gray-200 text-gray-900 text-sm rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 block w-full pl-8 p-3 dark:bg-gray-900 dark:border-gray-800 dark:text-white font-medium transition-all shadow-inner",
                                          placeholder: "e.g., Rewrite compiled regex pattern inside lookup loops",
                                          required: true %>

                    </div>
                  </div>

                  <!-- Content Description Entry Field Module -->
                  <div data-controller="step_content_tinymce">
                    <%= form.label :content, "Content*",
                                   class: "block mb-1.5 text-xs font-black uppercase tracking-wider text-gray-500 dark:text-gray-400" %>

                    <!-- Specialized WYSIWYG Editor Mock Boundary -->
                    <div class="border border-gray-200 dark:border-gray-800 rounded-xl overflow-hidden bg-gray-50 dark:bg-gray-900 shadow-inner group focus-within:ring-2 focus-within:ring-blue-500/20 focus-within:border-blue-500 transition-all">

                      <!-- Control Bar Subheader Toolbar Segment -->
                      <div class="flex flex-wrap items-center gap-1 p-2 bg-white dark:bg-gray-950 border-b border-gray-200 dark:border-gray-800">
                        <!-- Native Rails Form Text Area tied directly to the Stimulus JavaScript target -->
                        <%= form.text_area :content,
                                           "data-async_improvements-target" => "contentInput",
                                           data: { target: 'step_content_tinymce.field' },
                                           rows: 5,
                                           class: "block w-full p-4 text-sm text-gray-900 bg-transparent border-0 focus:outline-none dark:placeholder-gray-500 dark:text-white resize-y min-h-[140px]",
                                           placeholder: "Write content of improvement here",
                                           required: true %>
                      </div>
                    </div>


                    <br>
                    <!-- Content Description Entry Field Module -->
                    <div data-controller="step_content_tinymce">
                      <%= form.label :sources, "Sources",
                                     class: "block mb-1.5 text-xs font-black uppercase tracking-wider text-gray-500 dark:text-gray-400" %>
                      <!-- Specialized WYSIWYG Editor Mock Boundary -->
                      <div class="border border-gray-200 dark:border-gray-800 rounded-xl overflow-hidden bg-gray-50 dark:bg-gray-900 shadow-inner group focus-within:ring-2 focus-within:ring-blue-500/20 focus-within:border-blue-500 transition-all">
                          <!-- Native Rails Form Text Area tied directly to the Stimulus JavaScript target -->
                          <%= form.text_area :sources,
                                             "data-async_improvements-target" => "sourcesInput",
                                             data: { target: 'step_content_tinymce.field' },
                                             rows: 5,
                                             class: "block w-full p-4 text-sm text-gray-900 bg-transparent border-0 focus:outline-none dark:placeholder-gray-500 dark:text-white resize-y min-h-[140px]",
                                             placeholder: "List sources of information here",
                                             required: true %>
                        </div>
                      </div>

                    <!-- 4. GAMIFIED TAG ALLOCATION MODULE -->
                    <div data-controller="tags" class="space-y-1.5">
                      <div class="flex items-center justify-between">
                        <%= form.label :tag_list, "Tags",
                                       class: "block text-xs font-black uppercase tracking-wider text-gray-500 dark:text-gray-400" %>

                        <!-- Floating status helper badge -->
                        <span class="text-[9px] font-mono bg-cyan-500/10 text-cyan-500 dark:text-cyan-400 px-1.5 py-0.5 rounded border border-cyan-500/20 uppercase tracking-widest font-bold">
                          Max: 8 Tags
                        </span>
                      </div>

                      <div class="relative">
                        <!-- Hacking style hash indicator prefix -->
                        <span class="absolute inset-y-0 left-0 flex items-center pl-3.5 text-gray-400 text-sm font-mono">#</span>

                        <%= form.text_field :tag_list,
                                            class: "bg-gray-50 border border-gray-200 text-gray-900 text-sm rounded-xl focus:outline-none focus:ring-2 focus:ring-cyan-500/20 focus:border-cyan-500 block w-full pl-8 p-3 dark:bg-gray-900 dark:border-gray-800 dark:text-white font-mono transition-all shadow-inner",
                                            placeholder: "e.g., regex, cache, loop-optimization",
                                            required: false,
                                            data: { tags_target: "output" } %>
                      </div>

                      <!-- System Hint Matrix Footer Note -->
                      <p class="text-[10px] font-sans font-medium text-gray-400 dark:text-gray-500 leading-normal pl-1">
                        ⚡ <span class="font-bold text-gray-500 dark:text-gray-400">RECOMMENDED:</span> Up to 5 tokens. Separate distinct array values utilizing a comma (,).
                      </p>
                    </div>


                    <!-- Bottom Actions / Submission Row -->
                    <div class="pt-4 border-t border-gray-100 dark:border-gray-800/80 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
                      <div class="text-xs font-medium text-gray-400 flex items-center gap-1.5 font-mono">
                        <span class="inline-block w-1.5 h-1.5 rounded-full bg-emerald-500 animate-ping"></span>
                        <span>Active Connection Secure</span>
                      </div>

                      <!-- Native Rails submit button block layout matching the gamified orange design -->
                      <%= form.button type: :submit,
                                      class: "relative inline-flex items-center justify-center px-6 py-3.5 bg-gradient-to-r from-orange-500 to-amber-500 text-white font-black text-sm rounded-xl border border-yellow-300/40 hover:border-white transform active:scale-95 transition-all duration-150 uppercase tracking-wider hover:scale-[1.02] cursor-pointer shadow-lg shadow-orange-500/20" do %>
                        <span class="mr-2">⚡</span>
                        <span>Submit</span>
                        <span class="ml-3 inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-extrabold bg-gray-950 text-yellow-300 border border-yellow-400/30">
                        +50 XP
                      </span>
                      <% end %>
                    </div>
                <% end %> <!-- Closes the form_with block -->
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<hr class="w-48 h-1 mx-auto my-4 bg-gray-100 border-0 rounded md:my-10 dark:bg-gray-700">