<div class="bg-white border border-slate-200 rounded-2xl p-5 shadow-sm max-w-sm space-y-4">
  <div class="flex items-center justify-between border-b border-slate-100 pb-3">
    <div>
      <h3 class="text-xs font-black uppercase text-slate-400 tracking-wider">Physical Gateway</h3>
      <p class="text-sm font-bold text-slate-800">Share or Print Algorithm</p>
    </div>
    <span class="inline-flex items-center rounded-md bg-indigo-50 px-2 py-1 text-xs font-medium text-indigo-700 ring-1 ring-inset ring-indigo-700/10">
      Universal Link
    </span>
  </div>

  <!-- QR Code Viewbox Area -->
  <div class="flex flex-col items-center justify-center bg-slate-50 p-4 rounded-xl border border-slate-100 shadow-inner group relative mx-auto w-44 h-44">
    <% if @algorithm_version.qr_vector_blob.attached? %>
      <div class="w-36 h-36 flex items-center justify-center bg-white rounded-lg shadow-sm border border-slate-100 p-2 transition-transform duration-300 group-hover:scale-105">
        <%= @algorithm_version.qr_vector_blob.download.html_safe %>
      </div>
    <% else %>
      <!-- Fallback Generation Call if tracking code asset isn't compiled yet -->
      <div class="w-36 h-36 text-slate-400 flex flex-col items-center justify-center font-mono text-[10px] bg-white rounded border border-dashed border-slate-200 shadow-sm text-center p-2">
        <svg xmlns="http://w3.org" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6 mb-1 text-slate-300 animate-bounce">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v6m3-3H9m12 0a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        No Matrix Compiled
      </div>
    <% end %>
  </div>

  <p class="text-center text-[11px] text-slate-500 font-medium px-2">
    Scan this high-density matrix block to instantly launch this execution route loop on any smart device.
  </p>

  <!-- Share & Export Action Toolkit Grid -->
  <div class="grid grid-cols-2 gap-2 pt-2">

    <!-- Action 1: Native Print Trigger -->
    <button type="button"
            onclick="window.print();"
            class="flex items-center justify-center gap-2 py-2 px-3 bg-slate-100 hover:bg-slate-200 active:scale-[0.98] text-slate-700 text-xs font-bold rounded-xl transition-all cursor-pointer">
      <svg xmlns="http://w3.org" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6.72 13.82l-.24-7.49A2.25 2.25 0 018.72 4h6.56a2.25 2.25 0 012.24 2.33l-.24 7.49M21 12H3m14 0a2 2 0 11-4 0 2 2 0 014 0zm-10 0a2 2 0 11-4 0 2 2 0 014 0z" />
      </svg>
      Print Sheet
    </button>

    <!-- Action 2: File Download Controller Integration -->
    <% if @algorithm_version.qr_vector_blob.attached? %>
      <%= link_to rails_blob_path(@algorithm_version.qr_vector_blob, disposition: "attachment"),
                  class: "flex items-center justify-center gap-2 py-2 px-3 bg-indigo-600 hover:bg-indigo-700 active:scale-[0.98] text-white text-xs font-bold rounded-xl transition-all shadow-sm no-underline cursor-pointer" do %>
        <svg xmlns="http://w3.org" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
        </svg>
        Save Vector
      <% end %>
    <% else %>
      <button disabled class="flex items-center justify-center gap-2 py-2 px-3 bg-slate-200 text-slate-400 text-xs font-bold rounded-xl cursor-not-allowed">
        Unavailable
      </button>
    <% end %>

  </div>
</div>
