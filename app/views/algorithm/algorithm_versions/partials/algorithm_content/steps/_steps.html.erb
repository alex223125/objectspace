<div id="steps-for-algorithm-version-<%= algorithm_version.id%>">

  <hr class="w-48 h-1 mx-auto my-4 bg-gray-100 border-0 rounded md:my-10 dark:bg-gray-700">
  <div class="text-center col-span-6 sm:col-span-3">
    <p class="text-xl font-bold hover:text-gray-700">Steps:</p>
  </div>

  <% algorithm_version.control_structures.first.steps.each do |step| %>
    <%= render "algorithm/algorithm_versions/partials/algorithm_content/steps/step", step: step %>
  <% end %>
</div>
<br>


