<% if step.substeps.any? %>
  <div id="substeps-for-step-<%= step.id%>">

    <hr class="w-48 h-1 mx-auto my-4 bg-gray-100 border-0 rounded md:my-10 dark:bg-gray-700">
    <div class="text-center col-span-6 sm:col-span-3">
      <p class="text-xl font-bold hover:text-gray-700">Substeps:</p>
    </div>

    <% step.substeps.each do |substep| %>
      <%= render "algorithm/algorithm_versions/partials/algorithm_content/steps/substep", substep: substep %>
    <% end %>
    <hr class="w-48 h-1 mx-auto my-4 bg-gray-100 border-0 rounded md:my-10 dark:bg-gray-700">
  </div>
<% end %>


