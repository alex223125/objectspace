<div class="unit-substep-template">
  <!--    <div class="flex justify-center">-->

  Link so source page
  <br>
  <%= render "unit/unit_versions/partials/method_content/version_select_bar", unit_version: unit_version %>

  <div class="max-w-4xl p-4 rounded-lg bg-gray-50 dark:bg-gray-800">
    <!--center -->
    <div class="flex justify-between px-4 mx-auto max-w-screen-xl ">
      <div class="mx-auto w-full max-w-4xl format format-sm sm:format-base lg:format-lg format-blue dark:format-invert">
        <div class="mb-4 lg:mb-6 not-format">
          <h1 class="break-words mb-4 text-3xl font-extrabold leading-tight text-gray-900 lg:mb-6 lg:text-4xl dark:text-white">
            <%= unit_version.title %>
          </h1>


          <%= render "algorithm/algorithm_versions/partials/algorithm_content/steps/substeps_templates/unit/toc", unit_version: unit_version %>

        </div>


        <% if unit_version.solves_the_problem.present? %>
          <div class="break-words solves-the-problem-section" id="unit-solves-the-problem-<%= unit_version.id %>">
            # Solves the problem:
            <%= unit_version.solves_the_problem.html_safe %>
          </div>
          <br>
        <% end %>

        <div class="break-words instruction-section" id="unit-instruction-<%= unit_version.id %>">
          # Instruction:
          <%= unit_version.instruction.html_safe %>
        </div>
        <br>

        <% if unit_version.sources.present? %>
          <div class="break-words sources-section" id="unit-sources-<%= unit_version.id %>">
            # Sources:
            <%= unit_version.sources.html_safe %>
          </div>
          <br>
        <% end %>

        <% if unit_version.additional_information.present? %>
          <div class="break-words additional-information-section" id="unit-additional-information-<%= unit_version.id %>">
            # Additional information:
            <%= unit_version.additional_information.html_safe %>
          </div>
          <br>
        <% end %>

      </div>
    </div>
  </div>
  <!--    </div>-->
</div>