<div class="class-attributes-regular-fields">
  <div class="col-span-6 sm:col-span-3">
    <%= f.label "Title", class: "block text-sm font-medium text-gray-700" %>
    <%= f.hint 'Name attribute',
               class: "mt-2 text-sm text-gray-500" %>
    <%= f.input_field :title,
                      required: true,
                      class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm",
                      placeholder: "Ex: Solution stability, Solution flexibility, Solution performance" %>
  </div>
  <br>

  <div class="col-span-6 sm:col-span-3" data-controller="unit_instruction_tinymce">
    <%= f.label "Description (optional)", class: "block text-sm font-medium text-gray-700" %>
    <%= f.hint 'Use this filed to provide description of the attribute.', class: "mt-2 text-sm text-gray-500" %>
    <%= f.input_field :description,
                      placeholder: "You can describe why this attribute is important, how it changes if we use specific Methods and Algorithms.
                                    It is recommended to write here short description of attribute and write separately full version about attribute in a form of article.",
                      data: { target: 'unit_instruction_tinymce.field' } %>
  </div>
  <br>

  <% if @target_simple_class.present? %>
    <%= f.hidden_field :simple_class_id, value: @target_simple_class.id %>
  <% end %>


  <div class="attribute-fields-attribute-preview"
       data-controller="simple_class_attribute_preview"
       data-simple_class_attribute_preview-preview-type-value="regular_fields_form">
    <%= f.hidden_field :article_id, class: "article-id-hidden-field",
                       data: {target: "simple_class_attribute_preview.attributeIdHiddenField"} %>

    <div class="col-span-6 sm:col-span-3">
      <%= f.label "Attached Article", class: "block text-sm font-medium text-gray-700" %>
      <%= f.hint 'For more detailed description you can attach articles about this attribute.', class: "mt-2 text-sm text-gray-500" %>
      <div class="attribute-preview" data-target="simple_class_attribute_preview.attributePreviewContainer">
        <!-- place for injecting preview of article -->
      </div>
    </div>
    <br>
  </div>
  <%= render "shared/technologies_search/modal", :type => "simple_class_attribute_form_article_addition" %>
  <br>

  <% if @simple_class_attribute.present? ? !@simple_class_attribute.new_record? : false %>
    <div class="col-span-6 sm:col-span-3"
         id="remote-technologies-pick-container"
         data-controller="remote_technologies_pick"
         data-remote_technologies_pick-simple-class-id-value="<%= @simple_class_attribute.simple_class.id%>"
    >
      <%= f.label "Linked Actions", class: "block text-sm font-medium text-gray-700" %>
      <%= f.hint 'Use this input to make references with Methods and Algorithms which affect state of current attribute.
      For example if you have attribute Solution Performance you can pick Methods which are increase performance of your solution',
                 class: "mt-2 text-sm text-gray-500" %>

      <!-- selected technologies form input -->
      <div class="mb-6">
        <div class="relative mt-1 min-w-80 max-w-3xl">
<!--          <label for="items" class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">Selected Actions:</label>-->
          <div>
            <%= f.text_field :actions,
                        id: "items-form-input",
                        placeholder: "Use button below to add Action",
                        readonly: true,
                        class: "text-sm block w-full p-4 pl-10 text-sm text-gray-900 border border-gray-300 rounded-lg bg-gray-50 focus:ring-blue-500 focus:border-blue-500 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white dark:focus:ring-blue-500 dark:focus:border-blue-500",
                        data: {target: "remote_technologies_pick.itemsFormInput"} %>
<!--            <input type="text"-->
<!--                   name="items-form-input"-->
<!--                   readonly-->
<!--                   data-target="remote_technologies_pick.itemsFormInput"-->
<!--                   id="items-form-input"-->
<!--                   class="text-sm block w-full p-4 pl-10 text-sm text-gray-900 border border-gray-300 rounded-lg bg-gray-50 focus:ring-blue-500 focus:border-blue-500 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white dark:focus:ring-blue-500 dark:focus:border-blue-500"-->
<!--                   placeholder="Use button below to add Action"-->
<!--            >-->
          </div>
        </div>
      </div>

      <%= render "shared/technologies_pick/modal", type: "simple_class_attribute_form_action_pick", simple_class: @simple_class_attribute.simple_class %>
    </div>
  <% end %>

</div>
