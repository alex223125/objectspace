<div class="nested-fields nested-fields-interface-members" data-target="remote_select_instruction.interfaceMembersFields">

  <div class="" data-controller="step_accordion">

    <details class="" data-action="toggle->step_accordion#toggle" data-accordion-target="item">
      <summary
        class="flex items-center justify-between w-full p-5 font-medium text-left border border-gray-200 rounded-xl focus:ring-4 focus:ring-gray-200 dark:focus:ring-gray-800 dark:border-gray-700 hover:bg-gray-100 dark:hover:bg-gray-800 text-gray-500 dark:text-gray-400">
        <span>Action <span class="interface-member-position-visible-field"><%= interface_member.position%></span>: <%= interface_member.memberable.title %></span>
        <svg data-accordion-icon class="w-6 h-6 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13l-3 3m0 0l-3-3m3 3V8m0 13a9 9 0 110-18 9 9 0 010 18z"></path></svg>
      </summary>

      <div id="" aria-labelledby="accordion-arrow-icon-heading-2">
        <div class="p-5 font-light border border-b-0 border-gray-200 dark:border-gray-700">
          <div class="">

            <div class="interface-member-preview">
              <!-- TODO: create preview partials for each entity folder-->
              <% if interface_member.memberable_type == "Units::Unit" %>
                <%= render "shared/technologies_search/dpo_instruction_select/preview/unit", unit: interface_member.memberable %>
              <% elsif interface_member.memberable_type == "Algorithms::Algorithm" %>
                <% binding.pry %>
                <%= render "shared/technologies_search/dpo_instruction_select/preview/algorithm", algorithm: interface_member.memberable %>
              <% end %>
            </div>


            <br>
            <div class="bg-zinc-50 px-4 py-3 sm:px-6">


              <div class="text-end">
                <button data-action="click->remote_technologies_pick#addToCollection"
                        type="button"
                        data-target="remote_technologies_pick.addItemButton"
                        id="<%='add_item_button_' + interface_member.memberable.uniq_key%>"
                        class="relative inline-flex items-center justify-center p-0.5 mb-2 mr-2 overflow-hidden text-sm font-medium text-gray-900 rounded-lg group bg-gradient-to-br from-purple-600 to-blue-500 group-hover:from-purple-600 group-hover:to-blue-500 hover:text-white dark:text-white focus:ring-4 focus:outline-none focus:ring-blue-300 dark:focus:ring-blue-800" type="button">
                  <span
                    data-memberable-type="<%=interface_member.memberable_type%>"
                    data-memberable-id="<%=interface_member.memberable.id%>"
                    data-memberable-title="<%=interface_member.memberable.title%>"
                    data-button-uniq-key="<%=interface_member.memberable.uniq_key%>"
                    class="relative px-5 py-2.5 transition-all ease-in duration-75 bg-white dark:bg-gray-900 rounded-md group-hover:bg-opacity-0">
                    + Link with Attribute
                  </span>
                </button>


                <button type="button"
                        data-target="remote_technologies_pick.itemHasAddedButton"
                        id="<%= "item_has_added_button_" + interface_member.memberable.uniq_key%>"
                        class="hidden relative inline-flex items-center justify-center p-0.5 mb-2 mr-2 overflow-hidden text-sm font-medium text-gray-900 rounded-lg group bg-gradient-to-br from-purple-600 to-blue-500 group-hover:from-purple-600 group-hover:to-blue-500 hover:text-white dark:text-white focus:ring-4 focus:outline-none focus:ring-blue-300 dark:focus:ring-blue-800" type="button">
                  <span
                    class="relative px-5 py-2.5 transition-all ease-in duration-75 bg-white dark:bg-gray-900 rounded-md group-hover:bg-opacity-0">
                    + Item Added
                  </span>
                </button>


              </div>




            </div>

            <hr class="h-px my-8 bg-gray-200 border-0 dark:bg-gray-700">

          </div>
        </div>
        <hr class="w-48 h-1 mx-auto my-4 bg-gray-100 border-0 rounded md:my-10 dark:bg-gray-700">
      </div>
    </details>
  </div>
  <br>
</div>

