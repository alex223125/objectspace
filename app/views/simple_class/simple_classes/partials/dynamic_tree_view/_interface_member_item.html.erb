<div class="relative block p-2 overflow-hidden border bg-white rounded-lg ml-2 mr-6 max-w-4xl w-full hover:border-indigo-600 border-transparent border-2">

  <span class="absolute inset-x-0 bottom-0 h-2 bg-gradient-to-r from-green-300 via-blue-500 to-purple-600"></span>

  <div class="justify-between sm:flex">

    <div class="p-2 md:flex md:justify-center gap-2">
      <div class="flex-shrink-0 ml-3 sm:block">
        <img
          class="object-cover w-8 h-8 rounded-lg shadow-sm"
          src="https://github.com/creativetimofficial/argon-design-system/blob/master/assets/img/faces/team-2.jpg?raw=true"
          alt=""
          />
      </div>

      <div class="flex items-center justify-center">
        <h5 class="text-lg font-bold text-slate-900">
          <%= interface_member.try(:position) %>. <%= interface_member.memberable.title %>
        </h5>

        <% binding.pry %>
        <% if type == "technology_pick" %>
          <div data-action="click->remote_select_instruction#selectInstruction"
               data-instructionId="<%= interface_member.memberable.id %>"
               data-instructionType="<%= interface_member.memberable.class_key %>">
            <button type="button"
                    class="flex text-white right-2.5 bottom-2.5 bg-blue-700 hover:bg-blue-800 focus:ring-4 focus:outline-none focus:ring-blue-300 font-medium rounded-lg text-sm px-4 py-2 dark:bg-blue-600 dark:hover:bg-blue-700 dark:focus:ring-blue-800">
              Select
            </button>
          </div>
        <% end %>
      </div>
    </div>

  </div>

</div>