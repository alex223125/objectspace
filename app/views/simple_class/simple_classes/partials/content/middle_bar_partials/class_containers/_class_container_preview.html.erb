<div class="class-container">
  <!--title-->
  <h2 id="class-container-<%= class_container.id %>" class="text-2xl font-bold leading-7 text-gray-900 sm:truncate sm:text-1xl sm:tracking-tight text-center"># <%= class_container.title %>:</h2>

  <% if class_container.root? %>
    <!--    show nothing if root -->
  <% else %>
    <!--actions group description-->
    <div class="shadow-lg rounded-lg bg-white mx-auto m-8 p-4 notification-box">
      <div class="text-sm text-gray-600  tracking-tight ">
        <%= class_container.description.html_safe %>
      </div>
    </div>
    <br>
  <% end %>

  <!--preview container -->
  <div class="class-container-preview-container">
    <div class="relative col-start-2 col-end-3 lg:col-end-3 row-start-2 row-end-3 lg:row-start-3 lg:row-end-4 self-center pl-8 sm:px-6 md:px-8 pt-6 md:pt-8 lg:px-0 lg:pt-0">
      <div class="relative z-10 bg-white rounded-tl-xl sm:rounded-t-xl lg:rounded-xl shadow-lg divide-y divide-gray-100">

        <!--tabs -->
        <nav class="p-4 text-sm font-medium">
          <ul class="flex space-x-2" id="class-container-tab-<%= class_container.id %>"
              data-tabs-toggle="#myTabContentClassContainer<%= class_container.id %>" role="tablist">
            <li>
              <div class="px-4 py-2 rounded-md bg-amber-100 text-amber-700 cursor-pointer"
                   id="featured-tab-<%= class_container.id %>"
                   data-tabs-target="#featured-<%= class_container.id %>"
                   type="button"
                   role="tab"
                   aria-controls="featured-<%= class_container.id %>"
                   aria-selected="false">Featured
              </div>
            </li>
            <li>
              <div class="px-4 py-2 cursor-pointer"
                   id="popular-tab-<%= class_container.id %>"
                   data-tabs-target="#popular-<%= class_container.id %>"
                   type="button"
                   role="tab"
                   aria-controls="popular-<%= class_container.id %>"
                   aria-selected="false">Popular
              </div>
            </li>
            <li>
              <div class="px-4 py-2 cursor-pointer"
                   id="recent-tab-<%= class_container.id %>"
                   data-tabs-target="#recent-<%= class_container.id %>"
                   type="button"
                   role="tab"
                   aria-controls="recent-<%= class_container.id %>"
                   aria-selected="false">Recent
              </div>
            </li>
          </ul>
        </nav>

        <div id="myTabContentClassContainer<%= class_container.id %>">
          <div class="bg-gray-50 p-4 rounded-lg dark:bg-gray-800 hidden"
               id="featured-<%= class_container.id %>"
               role="tabpanel"
               aria-labelledby="featured-tab-<%= class_container.id %>">
            <%= render "simple_class/simple_classes/partials/content/middle_bar_partials/class_containers/container_members_list",
                       class_container: class_container %>


          </div>
          <div class="bg-gray-50 p-4 rounded-lg dark:bg-gray-800 hidden"
               id="popular-<%= class_container.id %>"
               role="tabpanel"
               aria-labelledby="popular-tab-<%= class_container.id %>">
            <%= render "simple_class/simple_classes/partials/content/middle_bar_partials/class_containers/container_members_list",
                       class_container: class_container %>
          </div>
          <div class="bg-gray-50 p-4 rounded-lg dark:bg-gray-800 hidden"
               id="recent-<%= class_container.id %>"
               role="tabpanel"
               aria-labelledby="recent-tab-<%= class_container.id %>">
            <%= render "simple_class/simple_classes/partials/content/middle_bar_partials/class_containers/container_members_list",
                       class_container: class_container %>
          </div>
          <!--          <div class="bg-gray-50 p-4 rounded-lg dark:bg-gray-800" id="dashboard" role="tabpanel" aria-labelledby="dashboard-tab">-->
          <!--            <p class="text-gray-500 dark:text-gray-400 text-sm">This is some placeholder content the <strong class="font-medium text-gray-800 dark:text-white">Dashboard tab's associated content</strong>. Clicking another tab will toggle the visibility of this one for the next. The tab JavaScript swaps classes to control the content visibility and styling.</p>-->
          <!--          </div>-->
          <!--          <div class="bg-gray-50 p-4 rounded-lg dark:bg-gray-800 hidden" id="settings" role="tabpanel" aria-labelledby="settings-tab">-->
          <!--            <p class="text-gray-500 dark:text-gray-400 text-sm">This is some placeholder content the <strong class="font-medium text-gray-800 dark:text-white">Settings tab's associated content</strong>. Clicking another tab will toggle the visibility of this one for the next. The tab JavaScript swaps classes to control the content visibility and styling.</p>-->
          <!--          </div>-->
          <!--          <div class="bg-gray-50 p-4 rounded-lg dark:bg-gray-800 hidden" id="contacts" role="tabpanel" aria-labelledby="contacts-tab">-->
          <!--            <p class="text-gray-500 dark:text-gray-400 text-sm">This is some placeholder content the <strong class="font-medium text-gray-800 dark:text-white">Contacts tab's associated content</strong>. Clicking another tab will toggle the visibility of this one for the next. The tab JavaScript swaps classes to control the content visibility and styling.</p>-->
          <!--          </div>-->
        </div>


      </div>
    </div>
  </div>

</div>
<hr class="w-48 h-1 mx-auto my-4 bg-gray-100 border-0 rounded md:my-10 dark:bg-gray-700">




