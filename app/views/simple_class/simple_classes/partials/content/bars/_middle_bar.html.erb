

<!--Content area-->
<div class="max-w-6xl p-4 rounded-lg bg-gray-50 dark:bg-gray-800" data-controller="content_area" data-target="content_area.area">
  <!--center -->
  <div class="flex justify-between px-4 mx-auto max-w-screen-xl ">
    <div class="w-full format-sm sm:format-base lg:format-lg format-blue dark:format-invert">
      <div class="mb-4 lg:mb-6 not-format p-3">
        <h1 class="break-words mb-4 text-3xl font-extrabold leading-tight text-gray-900 lg:mb-6 lg:text-4xl dark:text-white"><%= @simple_class.title %></h1>

        <!-- submenu -->
        <div class="mt-1 flex flex-col space-x-4 sm:mt-0 sm:flex-row sm:flex-wrap sm:space-x-6">

          <div class="mt-2 flex items-center text-sm">
            <%= render "simple_class/simple_classes/partials/content/bars/copy_to_clipboard", simple_class: simple_class %>
          </div>

          <div class="mt-2 flex items-center text-sm text-gray-500">
            <%= render "simple_class/simple_classes/partials/content/bars/options_dropdown", simple_class: simple_class %>
          </div>

          <div class="mt-2 flex items-center text-sm text-gray-500">
            <%= render "simple_class/simple_classes/partials/class_tree_map_modal", simple_class: simple_class %>
          </div>

          <div class="mt-2 flex items-center text-sm text-gray-500">
            bookmark button
          </div>
        </div>

        <!-- Sections Toc-->
        <%= render "simple_class/simple_classes/partials/content/bars/sections_toc", simple_class: @simple_class %>

        <div class="simple-class-content-area">
          <!--1.1 attributes section -->
          <%= render "simple_class/simple_classes/partials/content/middle_bar_partials/class_attributes/attributes_section", simple_class: @simple_class %>

          <!--1.2 instruction -->
          <% if @simple_class.functional_type_value == "decision_process_object_class" %>
            <%= render "simple_class/simple_classes/partials/content/middle_bar_partials/instruction",
                       instruction: @simple_class.instructionable %>
          <% end %>

          <!--1.3 interface groups section -->
          <%= render "simple_class/simple_classes/partials/content/middle_bar_partials/interface_groups/interface_group_section", simple_class: @simple_class %>

          <!--1.4 containers section (only for DOC) -->
          <% if @simple_class.functional_type_value == "decision_object_container_class" %>
            <%= render "simple_class/simple_classes/partials/content/middle_bar_partials/class_containers/containers_section", simple_class: @simple_class %>
          <% end %>
        </div>


      </div>
    </div>
  </div>
</div>

