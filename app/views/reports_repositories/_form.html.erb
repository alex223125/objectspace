<% path = @reports_repository.new_record? ? reports_repositories_path : reports_repository_path %>
<% method = @reports_repository.new_record? ? :post : :patch %>
<%= simple_form_for(@reports_repository, url: path, method: method) do |f| %>

  <% if reports_repository.errors.any? %>
    <div id="error_explanation" class="bg-red-50 text-red-500 px-3 py-2 font-medium rounded-lg mt-3">
      <h2><%= pluralize(repository.errors.count, "error") %> prohibited this repository from being saved:</h2>

      <ul>
        <% reports_repository.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-inputs">
    <div class="col-span-6 sm:col-span-3">
      <%= f.label "Reports repository title", class: "block text-sm font-medium text-gray-700" %>
      <%= f.hint 'Pick name for your repository', class: "mt-2 text-sm text-gray-500" %>
      <%= f.input_field :title,
                        required: true,
                        class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm",
                        placeholder: "Ex: How to install Ruby on Rails on your Desktop" %>
    </div>
    <br>

    <div class="col-span-6 sm:col-span-3" data-controller="repository_description_tinymce">
      <%= f.label "Description", class: "block text-sm font-medium text-gray-700" %>
      <%= f.hint 'Here you can describe wht you will store in repository',
                 class: "mt-2 text-sm text-gray-500" %>
      <%= f.input_field :description,
                        required: false,
                        class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm",
                        placeholder: "Ex: Different versions on how you can install Ruby on Rails on different environments",
                        data: { target: 'repository_description_tinymce.field' }%>
    </div>
    <br>

    <div class="col-span-6 sm:col-span-3" data-controller="tags">
      <%= f.label "Tags", class: "block text-sm font-medium text-gray-700" %>
      <%= f.hint "It is recommended to use no more than 5 tags. The maximum number is 8. Tags are separated by a comma.",
                 class: "mt-2 text-sm text-gray-500" %>
      <%= f.input_field :tag_list,
                        required: false,
                        class: "appearance-none block w-full px-3 py-2 border border-gray-300 rounded-md placeholder-gray-400 focus:outline-none focus:shadow-outline-blue focus:border-blue-300 transition duration-150 ease-in-out sm:text-sm sm:leading-5",
                        placeholder: "write some tags",
                        data: {target: "tags.output"}%>
    </div>
    <br>

    <!--  TODO: remove this, no private repos, only public on stage 1 -->
    <div class="col-span-6 sm:col-span-3">
      <%= f.label "Privacy settings", class: "block text-sm font-medium text-gray-700" %>
      <%= f.hint "By default your repository and it's content visible for everyone in internet", class: "mt-2 text-sm text-gray-500" %>
      <div class="flex items-center mb-4">
        <%= f.input_field :is_private,
                          class: "w-4 h-4 text-blue-600 bg-gray-100 border-gray-300 rounded focus:ring-blue-500 dark:focus:ring-blue-600 dark:ring-offset-gray-800 focus:ring-2 dark:bg-gray-700 dark:border-gray-600" %>
        <%= f.label "Make repository private", class: "ml-2 text-sm font-medium text-gray-900 dark:text-gray-300" %>
      </div>
    </div>

    <br>
  </div>
  <br>

  <div class="bg-gray-50 px-4 py-3 sm:px-6">
    <div class="text-end">
      <%= link_to "Back to dashboard", reports_repositories_path, class: "py-2.5 px-5 mr-2 mb-2 text-sm font-medium text-gray-900 focus:outline-none bg-white rounded-lg border border-gray-200 hover:bg-gray-100 hover:text-blue-700 focus:z-10 focus:ring-4 focus:ring-gray-200 dark:focus:ring-gray-700 dark:bg-gray-800 dark:text-gray-400 dark:border-gray-600 dark:hover:text-white dark:hover:bg-gray-700" %>
      <% button_text = @reports_repository.new_record? ? "Create Reports repository" : "Submit changes" %>
      <%= f.button :submit, button_text, class: "inline-flex justify-center rounded-md border border-transparent bg-indigo-600 py-2 px-4 text-sm font-medium text-white shadow-sm hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2" %>
    </div>
  </div>


<% end %>
