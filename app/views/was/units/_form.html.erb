<%= form_with(model: unit) do |form| %>
  <% if unit.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(unit.errors.count, "error") %> prohibited this unit from being saved:</h2>

      <ul>
        <% unit.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :title, style: "display: block" %>
    <%= form.text_field :title %>
  </div>

  <div>
    <%= form.label :instruction, style: "display: block" %>
    <%= form.text_area :instruction, :class => "tinymce", :rows => 20, :cols => 40 %>
    <%= render "tinymce" %>
  </div>

  <div>
    <%= form.submit %>
  </div>
<% end %>
