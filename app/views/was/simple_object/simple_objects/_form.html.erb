<%= simple_form_for(@simple_object, url: simple_object_simple_objects_path) do |f| %>


  <% if @simple_object.errors.any? %>
    <div id="error_explanation" class="bg-red-50 text-red-500 px-3 py-2 font-medium rounded-lg mt-3">
      <h2><%= pluralize(@simple_object.errors.count, "error") %> prohibited this Object from being saved:</h2>

      <ul>
        <% @simple_object.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-inputs">
    <div class="col-span-6 sm:col-span-3">
      <%= f.label "Title", class: "block text-sm font-medium text-gray-700" %>
      <%= f.hint 'Describe responsibility zone of process (method or algorithm). Can be the same as method or algorithm title.',
                 class: "mt-2 text-sm text-gray-500" %>
      <%= f.input_field :title,
                        required: true,
                        class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm",
                        placeholder: "Ex: How to install Ruby on Rails on your Desktop" %>
    </div>
    <br>

    <div class="col-span-6 sm:col-span-3">
      <%= f.label "Description", class: "block text-sm font-medium text-gray-700" %>
      <%= f.hint 'Thats the description which will be shown on the top of the source page',
                 class: "mt-2 text-sm text-gray-500" %>
      <%= f.input_field :description,
                        required: false,
                        class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm",
                        placeholder: "Ex: Different versions on how you can install Ruby on Rails on different environments" %>
    </div>
    <br>

    <%= f.hidden_field :type, :input_html => { value: SimpleObjects::TypeTypes[:decision_process_object] } %>

    <div data-controller="remote_select_instruction"
         data-target="remote_select_instruction.instructionableFieldsArea"
         data-remote_select_instruction-select-type-value="dpo_instruction_select">

      <div class="col-span-6 sm:col-span-3">
        <%= f.label "Method or Algorithm", class: "block text-sm font-medium text-gray-700" %>
        <%= f.hint 'Here you can pick method or algorithm around which you will create methodological toolbox',
                   class: "mt-2 text-sm text-gray-500" %>

        <%= f.hidden_field :instructionable_type, class: "instructionable-type-hidden-field" %>
        <%= f.hidden_field :instructionable_id, class: "instructionable-id-hidden-field" %>

      </div>
      <br>

      <div class="instruction-preview">
<!--        content of instruction-->
      </div>
      <br>

      <%= render "shared/technologies_search/modal", :type => "dpo_instruction_select" %>

    </div>

    <%= render "simple_class/simple_classes/partials/interface_groups/nested_form", :form => f %>


    <div class="bg-gray-50 px-4 py-3 sm:px-6">
      <div class="text-end">
        <%= link_to "Back to dashboard", algorithm_algorithms_path, class: "py-2.5 px-5 mr-2 mb-2 text-sm font-medium text-gray-900 focus:outline-none bg-white rounded-lg border border-gray-200 hover:bg-gray-100 hover:text-blue-700 focus:z-10 focus:ring-4 focus:ring-gray-200 dark:focus:ring-gray-700 dark:bg-gray-800 dark:text-gray-400 dark:border-gray-600 dark:hover:text-white dark:hover:bg-gray-700" %>
        <%= f.button :submit, "Create Decision process object", class: "inline-flex justify-center rounded-md border border-transparent bg-indigo-600 py-2 px-4 text-sm font-medium text-white shadow-sm hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2" %>
      </div>
    </div>

  </div>

<% end %>
