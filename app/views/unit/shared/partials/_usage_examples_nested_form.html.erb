  <p class="mt-2 text-sm text-gray-500">Here you can add examples how to use the method on practice with different cases and scenarios.</p>
  <%#= link_to "Add new usage example", units_path, class: "inline-flex justify-center rounded-md border border-transparent bg-indigo-600 py-2 px-4 text-sm font-medium text-white shadow-sm hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2" %>
</div>
<br>

<div>
  <%= form.fields_for :usage_examples do |t| %>
