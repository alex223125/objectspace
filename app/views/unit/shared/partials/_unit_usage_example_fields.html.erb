<div class="nested-fields">

  <div class="col-span-6 sm:col-span-3">
    <%= f.label "Title", class: "block text-sm font-medium text-gray-700" %>
    <%= f.hint 'Briefly describe context of example.', class: "mt-2 text-sm text-gray-500" %>
    <%= f.hint '"Example of sorting 2 dimensional arrays"', class: "mt-2 text-sm text-gray-500" %>
    <%= f.hint '"Example of cooking 2 dishes at the same time"', class: "mt-2 text-sm text-gray-500" %>
    <%= f.hint '"Example of paying all bills together"', class: "mt-2 text-sm text-gray-500" %>

    <%= f.input_field :title, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
  </div>
  <br>

  <div class="col-span-6 sm:col-span-3" data-controller="unit_usage_example_description_tinymce">
    <%= f.label "Description", class: "block text-sm font-medium text-gray-700" %>
    <%= f.hint 'Describe scenario or situation of method usage.', class: "mt-2 text-sm text-gray-500" %>
    <%= f.input_field :description, data: { target: 'unit_usage_example_description_tinymce.field' } %>
  </div>
  <br>

  <div class="col-span-6 sm:col-span-3" data-controller="unit_usage_example_sources_tinymce">
    <%= f.label "Sources (optional)", class: "block text-sm font-medium text-gray-700" %>
    <%= f.hint 'If your method based on any credible sources of information you can add it here.', class: "mt-2 text-sm text-gray-500" %>
    <%= f.input_field :sources, data: { target: 'unit_usage_example_sources_tinymce.field' } %>
  </div>

  <br>
  <div class="bg-zinc-50 px-4 py-3 sm:px-6">
    <div class="text-end">
      <%= link_to_remove_association "Delete", f, class: "focus:outline-none text-white bg-red-700 hover:bg-red-800 focus:ring-4 focus:ring-red-300 font-medium rounded-lg text-sm px-5 py-2.5 mr-2 mb-2 dark:bg-red-600 dark:hover:bg-red-700 dark:focus:ring-red-900" %>
<!--      <button type="button" class="focus:outline-none text-white bg-red-700 hover:bg-red-800 focus:ring-4 focus:ring-red-300 font-medium rounded-lg text-sm px-5 py-2.5 mr-2 mb-2 dark:bg-red-600 dark:hover:bg-red-700 dark:focus:ring-red-900">Remove</button>-->
    </div>
  </div>

  <hr class="h-px my-8 bg-gray-200 border-0 dark:bg-gray-700">
</div>