<% if unit_version.attachments.present? %>
  <div class="step-attachments">
    <p class="text-xl font-bold hover:text-gray-700">Attachments:</p>
    <ul>
      <% unit_version.attachments.each do |attachment| %>
        <% if attachment.type == AttachmentsHelper::ARTICLE_ATTACHMENT_TYPE %>
          <li class="text-body-color mb-4 flex text-base">
              <span class="text-primary mr-2 flex items-center rounded-full text-base">
                <svg width="20" height="8" viewBox="0 0 20 8" class="fill-current">
                  <path
                    d="M19.2188 2.90626L17.0625 0.343758C16.875 0.125008 16.5312 0.0937583 16.2812 0.281258C16.0625 0.468758 16.0312 0.812508 16.2188 1.06251L18.25 3.46876H0.9375C0.625 3.46876 0.375 3.71876 0.375 4.03126C0.375 4.34376 0.625 4.59376 0.9375 4.59376H18.25L16.2188 7.00001C16.0312 7.21876 16.0625 7.56251 16.2812 7.78126C16.375 7.87501 16.5 7.90626 16.625 7.90626C16.7812 7.90626 16.9375 7.84376 17.0312 7.71876L19.1875 5.15626C19.75 4.46876 19.75 3.53126 19.2188 2.90626Z"
                  ></path>
                </svg>
              </span>
            <button type="button"
                    data-action="click->attachment_preview#openModal"
                    data-attachment-uuid="<%= attachment.attachable.uuid %>"
                    data-attachment-type="<%= attachment.type %>"
                    class="hover:underline inline-flex text font-medium text-gray-700 hover:text-blue-600 dark:text-gray-400 dark:hover:text-white">
              <%= attachment.attachable.title %>
            </button>
          </li>
        <% end %>
      <% end %>
    </ul>
  </div>
<% end %>


