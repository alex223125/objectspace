<div id="top">
  <div class="pt-8 pb-16 lg:pt-16 lg:pb-24 bg-white dark:bg-gray-900">

    <div class="mb-4 border-b border-gray-200 dark:border-gray-700">
      <ul class="flex flex-wrap -mb-px text-sm font-medium text-center" id="myTab" data-tabs-toggle="#myTabContent" role="tablist">
        <li class="mr-2" role="presentation">
          <button class="inline-block p-4 border-b-2 rounded-t-lg" id="method-tab" data-tabs-target="#method" type="button"
                  role="tab" aria-controls="method" aria-selected="false" data-toggle="method-tab">Method</button>
        </li>
        <li class="mr-2" role="presentation">
          <button class="inline-block p-4 border-b-2 border-transparent rounded-t-lg hover:text-gray-600 hover:border-gray-300 dark:hover:text-gray-300"
                  id="improvements-tab" data-tabs-target="#improvements" type="button" role="tab"
                  aria-controls="improvements" aria-selected="false" data-toggle="method-tab">Improvements</button>
        </li>
        <li class="mr-2" role="presentation">
          <button class="inline-block p-4 border-b-2 border-transparent rounded-t-lg hover:text-gray-600 hover:border-gray-300 dark:hover:text-gray-300"
                  id="usage-examples-tab" data-tabs-target="#usage-examples" type="button" role="tab" aria-controls="usage-examples"
                  aria-selected="false" data-toggle="method-tab">Usage examples</button>
        </li>
        <li class="mr-2" role="presentation">
          <button class="inline-block p-4 border-b-2 border-transparent rounded-t-lg hover:text-gray-600 hover:border-gray-300 dark:hover:text-gray-300"
                  id="settings-tab" data-tabs-target="#settings" type="button" role="tab" aria-controls="settings"
                  aria-selected="false" data-toggle="method-tab">Settings</button>
        </li>
      </ul>
    </div>

    <div id="myTabContent">
<!--      <div class="flex justify-center">-->

<!--        <div class="" id="method" role="tabpanel" aria-labelledby="method-tab">-->
<!--        <div class="max-w-4xl hidden p-4 rounded-lg bg-gray-50 dark:bg-gray-800" id="method" role="tabpanel" aria-labelledby="method-tab">-->
      <div class="hidden p-4 rounded-lg h-full" id="method" role="tabpanel" aria-labelledby="method-tab">
        <!--        <p class="text-sm text-gray-500 dark:text-gray-400">This is some placeholder content the <strong class="font-medium text-gray-800 dark:text-white">Profile tab's associated content</strong>. Clicking another tab will toggle the visibility of this one for the next. The tab JavaScript swaps classes to control the content visibility and styling.</p>-->
        <%= render "unit/units/partials/method_content/main_page", unit: @unit %>
      </div>

<!--      <div class="hidden p-4 rounded-lg bg-gray-50 dark:bg-gray-800" id="improvements" role="tabpanel" aria-labelledby="improvements-tab">-->
      <div class="hidden p-4" id="improvements" role="tabpanel" aria-labelledby="improvements-tab">
        <%= render "unit/units/partials/improvements_content/main_page", unit: @unit %>
<!--        <p class="text-sm text-gray-500 dark:text-gray-400">This is some placeholder content the <strong class="font-medium text-gray-800 dark:text-white">Dashboard tab's associated content</strong>. Clicking another tab will toggle the visibility of this one for the next. The tab JavaScript swaps classes to control the content visibility and styling.</p>-->
      </div>

      <div class="hidden p-4 rounded-lg bg-gray-50 dark:bg-gray-800" id="usage-examples" role="tabpanel" aria-labelledby="usage-examples-tab">
        <%= render "unit/units/partials/usage_examples_content", unit: @unit %>
      </div>

      <div class="hidden p-4 rounded-lg bg-gray-50 dark:bg-gray-800" id="settings" role="tabpanel" aria-labelledby="settings-tab">
        <p class="text-sm text-gray-500 dark:text-gray-400">This is some placeholder content the <strong class="font-medium text-gray-800 dark:text-white">Settings tab's associated content</strong>. Clicking another tab will toggle the visibility of this one for the next. The tab JavaScript swaps classes to control the content visibility and styling.</p>
      </div>
    </div>

  </div>
</div>


<%= render "shared/scroll_to_top" %>