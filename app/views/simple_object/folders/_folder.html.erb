<div id="<%= dom_id folder %>">
  <p class="my-5">
    <strong class="block font-medium mb-1">Title:</strong>
    <%= folder.title %>
  </p>

  <p class="my-5">
    <strong class="block font-medium mb-1">Description:</strong>
    <%= folder.description %>
  </p>

  <% if action_name != "show" %>
    <%= link_to "Show this folder", folder, class: "rounded-lg py-3 px-5 bg-gray-100 inline-block font-medium" %>
    <%= link_to 'Edit this folder', edit_folder_path(folder), class: "rounded-lg py-3 ml-2 px-5 bg-gray-100 inline-block font-medium" %>
    <hr class="mt-6">
  <% end %>
</div>
