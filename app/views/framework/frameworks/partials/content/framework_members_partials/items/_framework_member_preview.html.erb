<div class="py-2 border-t-2 border-gray-100">
  <div class="flex flex-wrap lg:flex-nowrap items-center">
    <div class="w-full lg:w-auto px-4 mb-8 lg:mb-0">
      <img src="/_next/static/media/jucy-beef-burger.346917d5ccb0b705233bb1665ffb63f6.jpg" loading="lazy" alt="" width="144" height="144" class="flex-none w-18 h-18 rounded-lg object-cover bg-gray-100">
    </div>

    <div class="w-full lg:w-9/12 px-4 mb-10 lg:mb-0">
      <div class="max-w-2xl">

        <div class="absolute top-0 right-0 rounded-full bg-amber-50 text-amber-900 px-2 py-0.5 hidden sm:flex lg:hidden xl:flex items-center space-x-1"><dt class="text-amber-500"><span class="sr-only">Rating</span><svg width="16" height="20" fill="currentColor"><path d="M7.05 3.691c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.372 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.539 1.118l-2.8-2.034a1 1 0 00-1.176 0l-2.8 2.034c-.783.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.363-1.118L.98 9.483c-.784-.57-.381-1.81.587-1.81H5.03a1 1 0 00.95-.69L7.05 3.69z"></path></svg></dt><dd>4.94</dd></div>

        <div class="action-last-update-time">
          <span class="block text-gray-400 mb-1"><%= framework_member.updated_at.strftime("%B %d, %Y")%></span>
        </div>

        <div class="action-title">
          <!--                    <p class="text-2xl font-semibold text-gray-900">Consectures Dummy Content Velit officia consequat duis enim velit mollit adipsing</p>-->
          <p class="text-base sm:text-lg lg:text-base xl:text-lg font-semibold text-black mb-0.5"><%= framework_member.title %></p>
        </div>

        <div class="action-description">
          <p class="text-sm	 text-gray-900"><%= truncate(framework_member.description, length: 170, omission: '...', :escape => false) %></p>
        </div>

        <div class="action-author">
          <div class="text-sm	flex-none w-full mt-0.5 font-normal">
            <dt class="inline">By</dt>
            <dd class="inline text-black">Hank Douglas</dd>
          </div>
        </div>

      </div>
    </div>

    <!-- read button -->
    <div class="w-full lg:w-auto px-4 ml-auto text-right">
      <%= link_to framework_member_path(ownername: framework_member.closest_framework.ownerable.ownername, id: framework_member.slug), class: "inline-flex items-center text-xl font-semibold text-orange-900 hover:text-gray-900" do %>
        <span class="mr-2">Read</span>
        <svg class="animate-bounce" width="16" height="16" viewbox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M1.33301 14.6668L14.6663 1.3335" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
          <path d="M1.33301 1.3335H14.6663V14.6668" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
      <% end %>
    </div>

    <!-- OLD destroy button -->
<!--    <div class="w-full lg:w-auto px-4 ml-auto text-right">-->
      <%#= link_to framework_framework_member_path(framework_member), method: :delete, class: "inline-flex items-center text-xl font-semibold text-orange-900 hover:text-gray-900" do %>
<!--        <span class="mr-2">destroy</span>-->
<!--        <svg class="animate-bounce" width="16" height="16" viewbox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">-->
<!--          <path d="M1.33301 14.6668L14.6663 1.3335" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>-->
<!--          <path d="M1.33301 1.3335H14.6663V14.6668" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>-->
<!--        </svg>-->
      <%# end %>
<!--    </div>-->


    <!--    DESTROY BUTTON -->
    <!-- Modal toggle -->
<!--    original version-->
<!--    <div class="flex justify-center m-5">-->
<!--      <button id="deleteButton" data-modal-target="deleteModal" data-modal-toggle="deleteModal" class="block text-white bg-primary-700 hover:bg-primary-800 focus:ring-4 focus:outline-none focus:ring-primary-300 font-medium rounded-lg text-sm px-5 py-2.5 text-center dark:bg-primary-600 dark:hover:bg-primary-700 dark:focus:ring-primary-800" type="button">-->
<!--        Show delete confirmation-->
<!--      </button>-->
<!--    </div>-->

    <div class="delete-framework-member-modal" data-controller="delete_framework_member_modal">
      <div class="w-full lg:w-auto px-4 ml-auto text-right">
        <button data-target="delete_framework_member_modal.modalButton"
                data-action="click->delete_framework_member_modal#openModal"
                id="deleteButton<%=framework_member.uuid%>"
                class="" type="button">
          <div class = "inline-flex items-center text-xl font-semibold text-orange-900 hover:text-gray-900">
            <span class="mr-2">destroy</span>
            <svg class="animate-bounce" width="16" height="16" viewbox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M1.33301 14.6668L14.6663 1.3335" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
              <path d="M1.33301 1.3335H14.6663V14.6668" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
            </svg>
          </div>
        </button>
      </div>

      <!-- Main modal -->
      <div data-target="delete_framework_member_modal.modalBody" position="relative" z-index="50" id="deleteFrameworkMemberModal<%=framework_member.uuid%>" tabindex="-1" aria-hidden="true" class="hidden overflow-y-auto overflow-x-hidden fixed top-0 right-0 left-0 z-50 justify-center items-center w-full md:inset-0 h-modal md:h-full">
        <div class="relative p-4 w-full max-w-md h-full md:h-auto">
          <!-- Modal content -->
          <div class="relative p-4 text-center bg-white rounded-lg shadow dark:bg-gray-800 sm:p-5">
            <button type="button" class="text-gray-400 absolute top-2.5 right-2.5 bg-transparent hover:bg-gray-200 hover:text-gray-900 rounded-lg text-sm p-1.5 ml-auto inline-flex items-center dark:hover:bg-gray-600 dark:hover:text-white">
              <svg aria-hidden="true" class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"></path></svg>
              <span class="sr-only">Close modal</span>
            </button>
            <svg class="text-gray-400 dark:text-gray-500 w-11 h-11 mb-3.5 mx-auto" aria-hidden="true" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" d="M9 2a1 1 0 00-.894.553L7.382 4H4a1 1 0 000 2v10a2 2 0 002 2h8a2 2 0 002-2V6a1 1 0 100-2h-3.382l-.724-1.447A1 1 0 0011 2H9zM7 8a1 1 0 012 0v6a1 1 0 11-2 0V8zm5-1a1 1 0 00-1 1v6a1 1 0 102 0V8a1 1 0 00-1-1z" clip-rule="evenodd"></path></svg>
            <p class="mb-4 text-gray-500 dark:text-gray-300">Are you sure you want to delete this item?</p>
            <div class="flex justify-center items-center space-x-4">
              <button
                data-action="click->delete_framework_member_modal#closeModal"
                type="button"
                class="py-2 px-3 text-sm font-medium text-gray-500 bg-white rounded-lg border border-gray-200 hover:bg-gray-100 focus:ring-4 focus:outline-none focus:ring-primary-300 hover:text-gray-900 focus:z-10 dark:bg-gray-700 dark:text-gray-300 dark:border-gray-500 dark:hover:text-white dark:hover:bg-gray-600 dark:focus:ring-gray-600">
                No, cancel
              </button>
              <div >

              <%= link_to framework_framework_member_path(framework_member), method: :delete, class: "py-2 px-3 text-sm font-medium text-center text-white bg-red-600 rounded-lg hover:bg-red-700 focus:ring-4 focus:outline-none focus:ring-red-300 dark:bg-red-500 dark:hover:bg-red-600 dark:focus:ring-red-900" do %>
                <button
                  data-action="click->delete_framework_member_modal#closeModal"
                  type="button"
                  class="">
                  Yes, I'm sure
                </button>
              <% end %>
            </div>
          </div>
        </div>
      </div>
      </div>

    </div>






  </div>
</div>

