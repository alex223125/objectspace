<div id="<%= dom_id container_member %>">
  <% if action_name != "show" %>
    <%= link_to "Show this container member", container_member, class: "rounded-lg py-3 px-5 bg-gray-100 inline-block font-medium" %>
    <%= link_to 'Edit this container member', edit_container_member_path(container_member), class: "rounded-lg py-3 ml-2 px-5 bg-gray-100 inline-block font-medium" %>
    <hr class="mt-6">
  <% end %>
</div>
