<hr class="w-48 h-1 mx-auto my-4 bg-gray-100 border-0 rounded md:my-10 dark:bg-gray-700">

<!--<h2 class="text-2xl font-bold leading-7 text-gray-900 sm:truncate sm:text-3xl sm:tracking-tight text-center">Steps</h2>-->

<div class="nodraggablesteps col-span-6 sm:col-span-3">
  <p class="text-xl font-bold hover:text-gray-700">Framework members:</p>
  <p class="mt-2 text-sm text-gray-500">Here you can add examples how to use the method on practice with different cases
    and scenarios. Click on substep and move up or down to change position in the substeps list.</p>
</div>
<br>

<div class="steps-nested-form">

  <% select_type_value = "framework_members_form_framework_members_addition" %>
  <div data-controller="nodes_drag remote_select_instruction framework_member_addition framework_members_nested_form"
       data-target="remote_select_instruction.frameworkMembersFormFrameworkMembersArea nodes_drag.nodesArea"
       data-remote_select_instruction-select-type-value=<%= select_type_value %>>

    <!--    // Template: Framework Member-->
    <template data-target='framework_members_nested_form.regularFrameworkFieldsTemplate' class="framework-member-fields-template">
      <%= form.fields_for :framework_members, Frameworks::FrameworkMember.new, child_index: 'TEMPLATE_RECORD' do |framework_member| %>
        <%= render "framework/framework_members/new_members_partials/members/framework_member_fields", :f => framework_member %>
      <% end %>
    </template>

    <!-- TODO: change to addedItemsArea - that's the place where new records are added -->
    <div data-target="framework_members_nested_form.add_item">

    </div>

    <div class="hidden-addition-buttons">
      <!--      1.2 wrapper step original button -->
      <button data-action="click->framework_members_nested_form#add_association"
              data-framework-member-type="regular_member"
              data-child-index-keyword="TEMPLATE_RECORD"
              data-target="remote_select_instruction.addFrameworkMemberToFrameworkFolderInFrameworkMembersAdditionalFormOriginalButton"
              class="relative inline-flex items-center justify-center p-0.5 mb-2 mr-2 overflow-hidden text-sm font-medium text-gray-900 rounded-lg group bg-gradient-to-br from-purple-600 to-blue-500 group-hover:from-purple-600 group-hover:to-blue-500 hover:text-white dark:text-white focus:ring-4 focus:outline-none focus:ring-blue-300 dark:focus:ring-blue-800"
              type="button"
              style="display:none;"
      >
        <span class="relative px-5 py-2.5 transition-all ease-in duration-75 bg-white dark:bg-gray-900 rounded-md group-hover:bg-opacity-0">
          + Add new Framework Member
        </span>
      </button>
    </div>

    <!--    <div data-controller="algorithm_step_type_select">-->

    <!--    Option 1.Regular step-->

    <!--    Option 2.Wrapper step-->

    <%#= render "algorithm/shared/partials/shared/step_type_select_modal" %>


    <div class="block space-y-4 md:flex md:space-y-0 md:space-x-4">
      <!-- Modal toggle -->
      <button data-action="click->framework_member_addition#handleMemberAdditionButtonClick"
              class="relative inline-flex items-center justify-center p-0.5 mb-2 mr-2 overflow-hidden text-sm font-medium text-gray-900 rounded-lg group bg-gradient-to-br from-purple-600 to-blue-500 group-hover:from-purple-600 group-hover:to-blue-500 hover:text-white dark:text-white focus:ring-4 focus:outline-none focus:ring-blue-300 dark:focus:ring-blue-800"
              type="button">
        <span class="nodraggablesteps relative px-5 py-2.5 transition-all ease-in duration-75 bg-white dark:bg-gray-900 rounded-md group-hover:bg-opacity-0">
          Add Decision Box
        </span>
      </button>
    </div>

    <%#= render "shared/technologies_search/modal", :type => "algorithm_form_wrapper_step_addition" %>
    <%= render "shared/technologies_search/modal", :type => "framework_members_addition_form_member_addition" %>

  </div>
</div>

<!--  <div data-controller="sortable" data-sortable-url="/recipes/:recipe_id/steps/:id/step_position">-->
<%#= f.fields_for :steps, @recipe.steps.order(position: :asc) do |step| %>
<!--      <div data-id="<%#= step.object.id %>">-->
<%#= step.text_area :description %>
<!--      </div>-->
<%# end %>
<!--  </div>-->

<hr class="w-48 h-1 mx-auto my-4 bg-gray-100 border-0 rounded md:my-10 dark:bg-gray-700">


