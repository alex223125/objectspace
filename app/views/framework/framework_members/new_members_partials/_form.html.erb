<%= simple_form_for(@framework, url: create_members_framework_framework_members_path, method: :post) do |f| %>

  <% if @framework.errors.any? %>
    <div id="error_explanation" class="bg-red-50 text-red-500 px-3 py-2 font-medium rounded-lg mt-3">
      <h2><%= pluralize(@framework_member.errors.count, "error") %> prohibited this algorithm_version from being saved:</h2>

      <ul>
        <% [@framework, @framework_folder].errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <!--  <br>-->
  <%#= render "algorithm_preview", algorithm: @algorithm %>
  <!--  <br>-->

  <div class="form-inputs">
    <div>
      <%= f.simple_fields_for(:framework_folder, Frameworks::FrameworkFolder.new) do |framework_folder| %>
        <%= render "framework/framework_members/new_members_partials/framework_members_nested_form", :form => framework_folder %>
      <% end %>
    </div>

    <%= hidden_field_tag 'framework_folder', @target_framework_folder.uuid  %>
    <br>
  </div>
  <br>

  <div class="bg-gray-50 px-4 py-3 sm:px-6">
    <div class="text-end">
      <%= link_to "Back to dashboard", root_path, class: "py-2.5 px-5 mr-2 mb-2 text-sm font-medium text-gray-900 focus:outline-none bg-white rounded-lg border border-gray-200 hover:bg-gray-100 hover:text-blue-700 focus:z-10 focus:ring-4 focus:ring-gray-200 dark:focus:ring-gray-700 dark:bg-gray-800 dark:text-gray-400 dark:border-gray-600 dark:hover:text-white dark:hover:bg-gray-700" %>
      <%= f.button :submit, "Add Decision Boxes", class: "inline-flex justify-center rounded-md border border-transparent bg-indigo-600 py-2 px-4 text-sm font-medium text-white shadow-sm hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2" %>
    </div>
  </div>


<% end %>
