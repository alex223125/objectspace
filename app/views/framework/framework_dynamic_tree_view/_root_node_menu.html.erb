<% simple_classes_count = framework.included_simple_classes.length %>
<%# interface_members_count = 0  %>
<%# class_layer_entity.interface_groups.first.self_and_descendants.each do |interface_group| %>
  <%# interface_members_count += interface_group.interface_members.length  %>
<%# end %>



<!--<div class="relative block p-2 overflow-hidden border bg-white border-slate-100 rounded-lg ml-2 mr-6 w-full">-->

<!--<div class="relative block p-2 overflow-hidden bg-white rounded-lg ml-2 mr-6 w-full border-solid border-2 border-indigo-600">-->


<!--<div class="relative block p-2 overflow-hidden bg-white rounded-lg ml-2 mr-6 w-full border-2 hover:border-solid">-->
<div class="relative block p-2 overflow-hidden bg-white rounded-lg ml-2 mr-6 w-full border-4 border-indigo-200 border-l-indigo-500">
  <span class="absolute inset-x-0 bottom-0 h-2 bg-gradient-to-r from-green-300 via-blue-500 to-purple-600"></span>

  <div class="justify-between sm:flex">

    <div class="p-2 md:flex md:justify-center gap-2">
      <div class="flex-shrink-0 ml-3 sm:block">
        <img
          class="object-cover w-8 h-8 rounded-lg shadow-sm"
          src="https://github.com/creativetimofficial/argon-design-system/blob/master/assets/img/faces/team-2.jpg?raw=true"
          alt=""
          />
      </div>

      <div class="flex items-center justify-center">
        <h5 class="text-lg font-bold text-slate-900">
          <%= framework.title %>
        </h5>
      </div>
    </div>

  </div>

  <dl class="flex mt-4 ml-6 pb-4">
    <div class="flex ml-3 flex-col-reverse">
      <dt class="text-base font-medium text-slate-600">Decision boxes</dt>
      <dd class="text-base font-medium text-center"><%= simple_classes_count %></dd>
    </div>

    <div class="flex ml-3 sm:ml-3 flex-col-reverse">
      <dt class="text-base font-medium text-slate-600">Actions</dt>
      <dd class="text-base font-medium text-center">10</dd>
    </div>
  </dl>

</div>
