<% path = @framework_folder.new_record? ? framework_framework_folders_path : framework_framework_folder_path %>
<% method = @framework_folder.new_record? ? :post : :patch %>
<%= simple_form_for(@framework_folder, url: path, method: method) do |f| %>

  <% if @framework_folder.errors.any? %>
    <div id="error_explanation" class="bg-red-50 text-red-500 px-3 py-2 font-medium rounded-lg mt-3">
      <h2><%= pluralize(@framework_folder.errors.count, "error") %> prohibited this Class from being saved:</h2>

      <ul>
        <% @framework_folder.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-inputs">
    <div class="col-span-6 sm:col-span-3">
      <%= f.label "Title", class: "block text-sm font-medium text-gray-700" %>
      <%= f.hint 'Describe briefly what items you plan to store in folder',
                 class: "mt-2 text-sm text-gray-500" %>
      <%= f.input_field :title,
                        required: true,
                        class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm",
                        placeholder: "Ex: Methodologies how o create Ruby on Rails Blog applications" %>
    </div>
    <br>

    <div class="col-span-6 sm:col-span-3" data-controller="folder_description_tinymce">
      <%= f.label "Description", class: "block text-sm font-medium text-gray-700" %>
      <%= f.hint 'Describe in more detailed way responsibility of this folder. Thats the description which will be shown on the top of the source page',
                 class: "mt-2 text-sm text-gray-500" %>
      <%= f.input_field :description,
                        required: false,
                        class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm",
                        placeholder: "Ex: Different methodologies about ruby, ruby on rails, postgresql",
                        data: { target: 'folder_description_tinymce.field' }%>
    </div>
    <hr class="w-48 h-1 mx-auto my-4 bg-gray-100 border-0 rounded md:my-10 dark:bg-gray-700">

    <%= render "shared/form_partials/target_place" %>
    <%#= render "folders/partials/subfolders/nested_form", :form => f %>

    <div class="bg-gray-50 px-4 py-3 sm:px-6">
      <%#= link_to "Show this folder", target_folder_path(username: @folder.root.repository.user.username, id: folder.slug)  %>
      <div class="text-end">
        <% if @framework_folder.new_record? %>
          <%= link_to "Back to Folder", framework_framework_folder_path(ownername: @target_framework_folder.root.framework.ownerable.ownername, id: @target_framework_folder.slug), class: "py-2.5 px-5 mr-2 mb-2 text-sm font-medium text-gray-900 focus:outline-none bg-white rounded-lg border border-gray-200 hover:bg-gray-100 hover:text-blue-700 focus:z-10 focus:ring-4 focus:ring-gray-200 dark:focus:ring-gray-700 dark:bg-gray-800 dark:text-gray-400 dark:border-gray-600 dark:hover:text-white dark:hover:bg-gray-700" %>
          <%= f.button :submit, "Create Folder", class: "inline-flex justify-center rounded-md border border-transparent bg-indigo-600 py-2 px-4 text-sm font-medium text-white shadow-sm hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2" %>
        <% else %>
          <%= link_to "Back to Folder", framework_framework_folder_path(ownername: @framework_folder.root.framework.ownerable.ownername, id: @framework_folder.slug), class: "py-2.5 px-5 mr-2 mb-2 text-sm font-medium text-gray-900 focus:outline-none bg-white rounded-lg border border-gray-200 hover:bg-gray-100 hover:text-blue-700 focus:z-10 focus:ring-4 focus:ring-gray-200 dark:focus:ring-gray-700 dark:bg-gray-800 dark:text-gray-400 dark:border-gray-600 dark:hover:text-white dark:hover:bg-gray-700" %>
          <%= f.button :submit, "Update Folder", class: "inline-flex justify-center rounded-md border border-transparent bg-indigo-600 py-2 px-4 text-sm font-medium text-white shadow-sm hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2" %>
        <% end %>

      </div>
    </div>

  </div>

<% end %>
