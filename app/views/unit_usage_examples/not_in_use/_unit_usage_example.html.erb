<div id="<%= dom_id unit_usage_example %>">
  <p class="my-5">
    <strong class="block font-medium mb-1">Title:</strong>
    <%= unit_usage_example.title %>
  </p>

  <p class="my-5">
    <strong class="block font-medium mb-1">Description:</strong>
    <%= unit_usage_example.description %>
  </p>

  <p class="my-5">
    <strong class="block font-medium mb-1">Sources:</strong>
    <%= unit_usage_example.sources %>
  </p>

  <% if action_name != "show" %>
    <%= link_to "Show this unit usage example", unit_usage_example, class: "rounded-lg py-3 px-5 bg-gray-100 inline-block font-medium" %>
    <%= link_to 'Edit this unit usage example', edit_unit_usage_example_path(unit_usage_example), class: "rounded-lg py-3 ml-2 px-5 bg-gray-100 inline-block font-medium" %>
    <hr class="mt-6">
  <% end %>
</div>
