<div class="bg-gray-200 w-full min-h-screen flex items-center justify-center rounded">
  <div class="w-full py-8">
    <div class="flex items-center justify-center space-x-2">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-16 w-16 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 10l-2 1m0 0l-2-1m2 1v2.5M20 7l-2 1m2-1l-2-1m2 1v2.5M14 4l-2-1-2 1M4 7l2-1M4 7l2 1M4 7v2.5M12 21l-2-1m2 1l2-1m-2 1v-2.5M6 18l-2-1v-2.5M18 18l2-1v-2.5"></path>
      </svg>
      <h1 class="text-3xl font-bold text-blue-600 tracking-wider">Template</h1>
    </div>

    <div class="bg-white w-5/6 md:w-3/4 lg:w-2/4 xl:w-[500px] 2xl:w-[550px] mt-8 mx-auto px-16 py-8 rounded-lg shadow-2xl">

      <h2 class="text-center text-2xl font-bold tracking-wide text-gray-800">Sign Up</h2>
      <p class="text-center text-sm text-gray-600 mt-2">Already have an account? <%= link_to "Sign in here", new_user_session_path, class: "text-blue-600 hover:text-blue-700 hover:underline" %></p>


      <%= simple_form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put }) do |f| %>

        <div class="my-8 text-sm">

          <% if resource.errors.any? %>
            <div class="bg-red-50 border-l-8 border-red-900 mb-2">
              <div class="flex items-center">
                <div class="p-2">
                  <div class="flex items-center">
                    <div class="ml-2">
                      <svg class="h-8 w-8 text-red-900 mr-2 cursor-pointer"
                           xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
                           stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round"
                              stroke-width="2"
                              d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                      </svg>
                    </div>
                    <p class="px-6 py-4 text-red-900 font-semibold text-lg">Please fix the following errors.</p>
                  </div>
                  <div class="px-16 mb-4">
                    <% resource.errors.full_messages.each do |msg| %>
                      <li class="text-md text-red-500 text-sm"><%= msg %></li>
                    <% end %>
                  </div>
                </div>
              </div>
            </div>
          <% end %>


          <div class="flex items-center">
            <%= f.input_field :tos_agreement,
                              as: :boolean,
                              required: true,
                              class: "mr-2 focus:ring-0 rounded"%>
            <!--          <input type="checkbox" name="remember_me" id="remember_me" class="mr-2 focus:ring-0 rounded">-->

            <label for="tos_agreement" class="text-gray-700">I accept the <a href="#" class="text-blue-600 hover:text-blue-700 hover:underline">terms</a> and <a href="#" class="text-blue-600 hover:text-blue-700 hover:underline">privacy policy</a></label>
          </div>

          <div class="my-4 flex items-center justify-end space-x-4">
            <%= f.button :submit, "Complete sign up", class: "bg-blue-600 hover:bg-blue-700 rounded-lg px-8 py-2 text-gray-100 hover:shadow-xl transition duration-150 uppercase" %>
            <!--            <button class="bg-blue-600 hover:bg-blue-700 rounded-lg px-8 py-2 text-gray-100 hover:shadow-xl transition duration-150 uppercase">Sign Up</button>-->
          </div>
        </div>

      <% end %>


    </div>
  </div>
</div>
