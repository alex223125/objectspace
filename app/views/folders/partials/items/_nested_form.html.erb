<div class="">
  <div class="col-span-6 sm:col-span-3">
    <p class="text-xl font-bold hover:text-gray-700">Children classes:</p>


    <p class="mt-2 text-sm text-gray-500">Here you can add technologies to folder. See full list of available technologies here(link).</p>


    <%#= link_to "Add new usage example", units_path, class: "inline-flex justify-center rounded-md border border-transparent bg-indigo-600 py-2 px-4 text-sm font-medium text-white shadow-sm hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2" %>
  </div>
  <br>

  <!--  <div data-controller="interface_members_drag remote_select_instruction"-->
  <div data-controller="remote_select_instruction"
       data-drag-url="/todos/:id/move"
       data-target="remote_select_instruction.folderItemsArea "
       data-remote_select_instruction-select-type-value="folder_item_addition"
  >


    <!-- !!!!  Association articles used only for cocoon gem working, on practice where can be any sort of technology -->
    <%= form.fields_for :articles do |t| %>

      <%= render "folders/partials/items/item_fields", :f => t %>

    <% end %>
    <!-- !!!!  Association articles used only for cocoon gem working, on practice where can be any sort of technology -->



    <!--      <div data-target="remote_select_instruction.addSubstepOriginalButton">-->
    <div>
      <%= link_to_add_association "Add member", form,
                                  :articles,
                                  partial: 'folders/partials/items/item_fields',
                                  style: "display:none;",
                                  class: "nodraggablesubsteps flex text-white right-2.5 bottom-2.5 bg-blue-700 hover:bg-blue-800 focus:ring-4 focus:outline-none focus:ring-blue-300 font-medium rounded-lg text-sm px-4 py-2 dark:bg-blue-600 dark:hover:bg-blue-700 dark:focus:ring-blue-800",
                                  data: {target: "remote_select_instruction.addFolderItemOriginalButton"}%>
    </div>


    <%= render "shared/technologies_search/modal", :form => form, :type => "folder_item_addition" %>


  </div>

</div>
<hr class="w-48 h-1 mx-auto my-4 bg-gray-100 border-0 rounded md:my-10 dark:bg-gray-700">