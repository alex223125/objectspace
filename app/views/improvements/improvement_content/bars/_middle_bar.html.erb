<div class="max-w-6xl p-4 rounded-lg bg-gray-50 dark:bg-gray-800">
  <!--center -->
  <div class="flex justify-between px-4 mx-auto max-w-screen-xl">
    <div class="w-full format-sm sm:format-base lg:format-lg format-blue dark:format-invert">
      <div class="mb-4 lg:mb-6 not-format p-3">
        <h1 class="break-words mb-4 text-3xl font-extrabold leading-tight text-gray-900 lg:mb-6 lg:text-4xl dark:text-white">
          <%= improvement.title %>
        </h1>

        <!-- submenu -->
        <div class="mt-1 flex flex-col space-x-4 sm:mt-0 sm:flex-row sm:flex-wrap sm:space-x-6">
          <div class="mt-2 flex items-center text-sm text-gray-500">
            <%= render "improvements/improvement_content/submenu/options_dropdown", improvement: improvement %>
          </div>
        </div>

        <%= render "improvements/improvement_content/toc", improvement: improvement %>
        <br>
      </div>



      <div class="break-words content-section" id="content-section-<%=improvement.uniq_key%>">
        # Content:
        <%= improvement.content.html_safe %>
      </div>
      <br>

      <% if improvement.sources.present? %>
        <div class="break-words sources-section" id="sources-section-<%=improvement.uniq_key%>">
          # Sources:
          <%= improvement.sources.html_safe %>
        </div>
        <br>
      <% end %>

<!--      <div class="attachments" data-controller="attachment_preview">-->
        <%#= render "unit/unit_versions/partials/method_content/attachments", improvement: improvement %>
        <%#= render "shared/attachment_preview/modal" %>
<!--      </div>-->

      <%#= render "unit/unit_versions/partials/method_content/contribute", improvement: improvement %>
<!--      <br>-->

      <%= render "comments/index", commentable: @commentable, comment: @comment, scenario: "improvement_page" %>

    </div>
  </div>
</div>