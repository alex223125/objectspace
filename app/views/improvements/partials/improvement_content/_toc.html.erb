<!--      TOC-->
<div class="improvement-toc" data-controller="toc_scrolling" data-toc_scrolling-type-value="<%=toc_type%>">
  <br>
  Table of content:
  <ul role="list" a="" class="space-y-3 text-base list-none sm:text-lg md:mt-5 md:text-xl">

    <li>
      <a class="hover:underline hover:text-blue-600 font-light text-waterloo dark:text-santa hover:text-oyster dark:hover:text-oyster"
         onclick="return false;"
         href="#content-section-<%=improvement.uuid%>"
         data-action="click->toc_scrolling#scroll"
         data-anchor="#content-section-<%=improvement.uuid%>"
      >
        ↳ Content
      </a>
    </li>

    <% if improvement.sources.present? %>
      <li>
        <a class="hover:underline hover:text-blue-600 font-light text-waterloo dark:text-santa hover:text-oyster dark:hover:text-oyster"
           onclick="return false;"
           href="#sources-section-<%=improvement.uuid%>"
           data-action="click->toc_scrolling#scroll"
           data-anchor="#sources-section-<%=improvement.uuid%>"
        >
          ↳ Sources
        </a>
      </li>
    <% end %>

    <li>
      <a class="hover:underline hover:text-blue-600 font-light text-waterloo dark:text-santa hover:text-oyster dark:hover:text-oyster"
         onclick="return false;"
         href="#contribute-<%=improvement.uuid%>"
         data-action="click->toc_scrolling#scroll"
         data-anchor="#contribute-<%=improvement.uuid%>"
      >
        ↳ Contribute
      </a>
    </li>

    <li>
      <a class="hover:underline hover:text-blue-600 font-light text-waterloo dark:text-santa hover:text-oyster dark:hover:text-oyster"
         onclick="return false;"
         href="#comments-<%=improvement.uniq_key%>"
         data-action="click->toc_scrolling#scroll"
         data-anchor="#comments-<%=improvement.uniq_key%>"
      >
        ↳ Comments
      </a>
    </li>
  </ul>
</div>