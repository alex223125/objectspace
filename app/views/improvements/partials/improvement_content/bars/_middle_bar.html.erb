<div class="max-w-6xl p-4 rounded-lg bg-gray-50 dark:bg-gray-800">
  <!--center -->
  <div class="flex justify-between px-4 mx-auto max-w-screen-xl">
    <div class="w-full format-sm sm:format-base lg:format-lg format-blue dark:format-invert">
      <div class="mb-4 lg:mb-6 not-format p-3">
        <h1 class="break-words mb-4 text-3xl font-extrabold leading-tight text-gray-900 lg:mb-6 lg:text-4xl dark:text-white">
          <%= improvement.title %>
        </h1>

        <!-- submenu -->
        <div class="mt-1 flex flex-col space-x-4 sm:mt-0 sm:flex-row sm:flex-wrap sm:space-x-6">
          <div class="mt-2 flex items-center text-sm text-gray-500">
            <%= render "improvements/partials/improvement_content/submenu/options_dropdown", improvement: improvement %>
          </div>
        </div>

        <%= render "improvements/partials/improvement_content/toc", improvement: improvement, toc_type: "toc_for_regular_page" %>
        <br>
      </div>

      <div class="content-section break-words" id="content-section-<%=improvement.uuid%>">
        <a href="#content-section-<%=improvement.uuid%>">
          <h3 class="hover:underline hover:text-blue-600 text-2xl font-bold leading-7 text-gray-900 sm:truncate sm:text-1xl sm:tracking-tight text-center">Content</h3>
        </a>
        <%= improvement.content.html_safe %>
      </div>
      <br>


      <% if improvement.sources.present? %>
        <div class="sources-section break-words" id="sources-section-<%=improvement.uuid%>">
          <a href="#sources-section-<%=improvement.uuid%>">
            <h3 class="hover:underline hover:text-blue-600 text-2xl font-bold leading-7 text-gray-900 sm:truncate sm:text-1xl sm:tracking-tight text-center">Sources</h3>
          </a>
          <%= improvement.sources.html_safe %>
        </div>
        <br>
      <% end %>

      <%= render "improvements/partials/improvement_content/contribute", improvement: improvement %>
      <br>

      <%= render "comments/index", commentable: @commentable, comment: @comment, scenario: "improvement_page" %>

    </div>
  </div>
</div>