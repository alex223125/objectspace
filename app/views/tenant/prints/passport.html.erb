<%# app/views/tenant/prints/passport.html.erb %>
<div class="p-8 border-4 border-slate-200 rounded-3xl bg-white max-w-4xl mx-auto font-sans text-slate-800">
  <div class="flex justify-between items-start border-b-2 border-slate-100 pb-6 mb-6">
    <div>
      <span class="text-[10px] font-bold text-indigo-600 uppercase tracking-widest block">System Passport Blueprint</span>
      <h1 class="text-3xl font-black text-slate-900 tracking-tight mt-1"><%= @algorithm_version&.print_title.presence || "Verified Cryptographic Schema" %></h1>
      <p class="text-xs text-slate-500 mt-2 leading-relaxed max-w-xl">
        <%= @algorithm_version&.short_print_description.presence || "No short operational deployment summary card criteria configured for this iteration." %>
      </p>
    </div>
    <div class="text-right">
      <span class="inline-flex items-center rounded-full bg-indigo-50 px-3 py-1 text-xs font-mono font-bold text-indigo-700 border border-indigo-100">
        TOK: <%= @algorithm_version&.cached_qr_short_token %>
      </span>
    </div>
  </div>

  <div class="flex flex-col items-center justify-center bg-slate-50 p-6 rounded-2xl border border-slate-200 w-52 h-52 mx-auto my-8 shadow-inner">
    <div class="w-44 h-44 bg-white p-2 rounded-xl shadow border border-slate-100 flex items-center justify-center">
      <% if defined?(svg_matrix_content) && svg_matrix_content.present? %>
        <%= svg_matrix_content.html_safe %>
      <% else %>
        <div class="text-xs font-mono text-slate-400">[ Vector Array ]</div>
      <% end %>
    </div>
  </div>

  <div class="border-t border-slate-100 pt-4 flex justify-between items-center text-[10px] font-mono text-slate-400">
    <span>Objectspace Verified Asset Passport Ledger</span>
    <span>https://onrender.com</span>
  </div>
</div>
