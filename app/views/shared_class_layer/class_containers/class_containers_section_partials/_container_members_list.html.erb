<!--content -->
<section class="relative py-2 overflow-hidden">
  <div class="relative container px-4 mx-auto">

    <div class="max-w-5xl mx-auto">

      <% binding.pry %>
      <% if class_container.content_present? %>

        <section class="relative py-2 overflow-hidden">
          <div class="relative container px-4 mx-auto">
            <h2 class="text-2xl font-bold leading-7 text-gray-900 sm:truncate sm:text-1xl sm:tracking-tight text-center">Part 1.Children class container:</h2>
            <% if class_container.containers.present? %>
              <div class="max-w-8xl mx-auto">
                <% class_container.containers.each do |class_container| %>
                  <%= render "shared_class_layer/class_containers/class_containers_section_partials/items/child_class_container_preview", class_container: class_container %>
                <% end %>
              </div>
            <% else %>
              No class containers (add new)
            <% end %>

            <% if ClassContainers::BelongsToStructureTypes[class_container.belongs_to_structure_type] == "belongs_to_simple_class" %>
              <h2 class="text-2xl font-bold leading-7 text-gray-900 sm:truncate sm:text-1xl sm:tracking-tight text-center">Part 2.Current layer interface groups (actions groups):</h2>
              <% if class_container.interface_groups.present? %>
                <div class="max-w-8xl mx-auto">
                  <% class_container.interface_groups.each do |interface_group| %>
                    <%= render "shared_class_layer/class_containers/class_container_show_partials/container_interface_group_preview", interface_group: interface_group %>
                  <% end %>
                </div>
              <% else %>
                No container members (add new)
              <% end %>
            <% end %>

            <h2 class="text-2xl font-bold leading-7 text-gray-900 sm:truncate sm:text-1xl sm:tracking-tight text-center">Part 3.Current layer technologies:</h2>
            <% if class_container.container_members.present? %>
              <div class="max-w-8xl mx-auto">
                <% class_container.container_members.each do |container_member| %>
                  <% binding.pry %>
                  <%= render "shared_class_layer/class_containers/class_containers_section_partials/items/container_member_preview",
                             container_member: container_member %>

                <% end %>
              </div>
            <% else %>
              No container members (add new)
            <% end %>


          </div>
        </section>

        <!--         See more button -->
        <div class="pt-12 border-t-2 border-gray-100 text-center">
          <%= link_to class_container_path(ownername: class_container.related_class_layer_entity.ownerable.ownername, id: class_container.slug), class: "relative group inline-block py-4 px-7 font-semibold text-orange-900 hover:text-orange-50 rounded-full bg-orange-50 transition duration-300 overflow-hidden" do %>
            <div class="absolute top-0 right-full w-full h-full bg-gray-900 transform group-hover:translate-x-full group-hover:scale-102 transition duration-500"></div>
            <span class="relative">See More Components</span>
          <% end %>
        </div>

        <!--          // Articles -->
        <%# class_container.container_members.last(3).each do |container_member| %>
        <%#= render "simple_class/simple_classes/partials/content/middle_bar_partials/class_containers/container_member_preview", simple_class: container_member.memberable %>
        <%# end %>

      <% else %>

        <% if current_user.try(:has_resource_modify_permissions?, class_container) %>
          <!--  nothing found card for owner of class  -->
          <div class="max-w-4xl p-6 bg-white border border-gray-200 rounded-lg shadow dark:bg-gray-800 dark:border-gray-700">
            <a href="#">
              <h5 class="mb-2 text-2xl font-bold tracking-tight text-gray-900 dark:text-white">This Component doesn't have any Child Components</h5>
            </a>
            <p class="mb-3 font-normal text-gray-700 dark:text-gray-400">To add new Components inside this Component use the button below.</p>
<!--            <div class="flex justify-center">-->
              <%#= render "simple_class/simple_classes/partials/add_new_container_member_options_modal", type: "no_container_members_in_class_container", target_class_container: class_container %>
<!--            </div>-->
          </div>
        <% else %>
          <!--  nothing found card for visitors -->
          <div class="max-w-4xl p-6 bg-white border border-gray-200 rounded-lg shadow dark:bg-gray-800 dark:border-gray-700">
            <a href="#">
              <h5 class="mb-2 text-2xl font-bold tracking-tight text-gray-900 dark:text-white">Nothing found
              </h5>
            </a>
            <p class="mb-3 font-normal text-gray-700 dark:text-gray-400">Owner of this Decision Box didn't added any components yet.</p>
          </div>
        <% end %>

      <% end %>

    </div>
  </div>
</section>