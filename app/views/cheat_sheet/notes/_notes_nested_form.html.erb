<div class="col-span-6 sm:col-span-3" id="notes-nested-form">
  <%= f.fields_for :notes do |note| %>
    <%= render "cheat_sheet/notes/note_fields", :f => note %>
  <% end %>

  <br>
  <div class="add-new-attachment-button">
    <%= link_to_add_association "+ Add new Note", f,
      :notes,
      partial: 'cheat_sheet/notes/note_fields',
      class: "nodraggablesteps inline-flex justify-center rounded-md border border-transparent bg-indigo-600 py-2 px-4 text-sm font-medium text-white shadow-sm hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2"
    %>
  </div>
</div>


